<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:svc="clr-namespace:ClaudetRelay.Services;assembly=ClaudetRelay">
    <svc:ProjectTypeDefinition x:Key="ProjectType"
        Name="Business Project"
        Icon="💼"
        Description="A business plan, marketing campaign, product launch or organisational project. Track phases, tasks, assignees and deadlines."
        StructureHierarchy="Phase|Task"
        StructureIcons="📋|✅"
        HasRoadmap="True"
        HasWorldBuilding="False"
        HasAssignees="True"
        HasDeadlines="True"
        SystemPromptHint="You are collaborating on a business project. Think strategically: define clear goals, identify risks and dependencies, propose measurable milestones, and communicate in a professional register. Every output should be actionable and appropriate for its audience. Clearly distinguish between confirmed facts, assumptions, and recommendations — and be direct about uncertainty. Phases and tasks should have clear owners and success criteria."/>
</ResourceDictionary>
