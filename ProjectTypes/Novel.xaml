<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:svc="clr-namespace:ClaudetRelay.Services;assembly=ClaudetRelay">
    <svc:ProjectTypeDefinition x:Key="ProjectType"
        Name="Novel"
        Icon="📖"
        Description="A work of long-form fiction. Organise your story into chapters and scenes, build a cast of characters, factions and locations, and track your plot notes."
        StructureHierarchy="Chapter|Scene"
        StructureIcons="📖|🎬"
        WorldFolders="Characters|Factions|Locations"
        HasRoadmap="True"
        HasWorldBuilding="True"
        HasPlotNotes="True"
        SystemPromptHint="You are co-writing a novel. Think in terms of plot arcs, character development, scene pacing, narrative voice, and internal story consistency. When writing prose, match the established tone and style of the project. Flag plot holes or character inconsistencies when you spot them. Respect world-building already defined in the project — characters, factions and locations should be treated as canon unless the user explicitly revises them."/>
</ResourceDictionary>
