<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:svc="clr-namespace:ClaudetRelay.Services;assembly=ClaudetRelay">
    <svc:ProjectTypeDefinition x:Key="ProjectType"
        Name="Theatre"
        Icon="🎭"
        Description="A stage play or screenplay. Organise your script into acts and scenes, manage your cast of characters and track stage directions."
        StructureHierarchy="Act|Scene"
        StructureIcons="🎭|🎬"
        WorldFolders="Characters|Locations"
        HasRoadmap="True"
        HasWorldBuilding="True"
        HasPlotNotes="True"
        HasStageDirections="True"
        SystemPromptHint="You are collaborating on a stage play or screenplay. Think in terms of dramatic tension, character voice, scene structure, and visual storytelling. Format dialogue in standard playscript style when writing script content. Consider what is shown versus what is spoken — theatre communicates through action and presence as much as words. Stage directions should be specific and performable. Respect character voices and relationships already established in the script."/>
</ResourceDictionary>
