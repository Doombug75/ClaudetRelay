<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:svc="clr-namespace:ClaudetRelay.Services;assembly=ClaudetRelay">
    <svc:ProjectTypeDefinition x:Key="ProjectType"
        Name="Theatre"
        Icon="🎭"
        Description="A stage play or screenplay. Organise your script into acts and scenes, manage your cast of characters and track stage directions."
        StructureHierarchy="Act|Scene"
        StructureIcons="🎭|🎬"
        WorldFolders="Characters|Locations"
        HasRoadmap="True"
        HasWorldBuilding="True"
        HasPlotNotes="True"
        HasStageDirections="True"
        SystemPromptHint="This is a theatre/screenplay writing project. The script is organised into acts and scenes. Characters and locations are defined in the world-building section. Stage directions and production notes are supported."/>
</ResourceDictionary>
