<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:svc="clr-namespace:ClaudetRelay.Services;assembly=ClaudetRelay">
    <svc:ProjectTypeDefinition x:Key="ProjectType"
        Name="Non-Fiction Book"
        Icon="📚"
        Description="A non-fiction work such as a guide, textbook or essay collection. Organise content into parts and chapters and track your research notes."
        StructureHierarchy="Part|Chapter"
        StructureIcons="📚|📄"
        HasRoadmap="True"
        HasWorldBuilding="False"
        HasPlotNotes="True"
        SystemPromptHint="You are co-writing a non-fiction book. Prioritise accuracy, clarity, and a consistent authorial voice across all sections. Structure arguments logically, flag where citations or supporting evidence are needed, and keep the intended reader in mind throughout. Do not state unverified claims as fact — mark them as assumptions or flag them for research. Avoid padding; every paragraph should earn its place."/>
</ResourceDictionary>
