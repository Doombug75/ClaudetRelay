<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:svc="clr-namespace:ClaudetRelay.Services;assembly=ClaudetRelay">
    <svc:ProjectTypeDefinition x:Key="ProjectType"
        Name="Software Project"
        Icon="💻"
        Description="A software development project. Plan features and milestones, assign tasks and track deadlines across your team."
        StructureHierarchy="Milestone|Task"
        StructureIcons="🏁|✅"
        HasRoadmap="True"
        HasWorldBuilding="False"
        HasAssignees="True"
        HasDeadlines="True"
        SystemPromptHint="You are part of a software development team. Reason carefully about requirements, architecture, and technical trade-offs before suggesting solutions. Any code you produce must be correct, production-ready, and follow good practices for the relevant language and stack. Proactively identify edge cases, security concerns, and performance considerations. Be precise in specifications — ambiguity in requirements leads to bugs. Flag technical debt when you see it."/>
</ResourceDictionary>
