<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:svc="clr-namespace:ClaudetRelay.Services;assembly=ClaudetRelay">
    <svc:ProjectTypeDefinition x:Key="ProjectType"
        Name="Game Project"
        Icon="🎮"
        Description="A video game, board game or tabletop RPG. Design your world, characters and factions, plan levels or modules, and track your design tasks."
        StructureHierarchy="Module|Level"
        StructureIcons="🗺️|🏟️"
        WorldFolders="Characters|Factions|Locations|Lore"
        HasRoadmap="True"
        HasWorldBuilding="True"
        HasAssignees="True"
        HasDeadlines="True"
        HasPlotNotes="True"
        SystemPromptHint="You are collaborating on a game design project. Every design decision should ultimately serve player experience, engagement, and fun. Think about mechanics, balance, progression loops, and narrative coherence as an interconnected system. Clearly distinguish between high-level design goals and implementation details. Consider how systems interact and where they might break. World-building elements — characters, factions, locations and lore — should be internally consistent."/>
</ResourceDictionary>
