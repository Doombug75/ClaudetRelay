<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:svc="clr-namespace:ClaudetRelay.Services;assembly=ClaudetRelay">
    <svc:ProjectTypeDefinition x:Key="ProjectType"
        Name="General"
        Icon="📁"
        Description="A general-purpose project for any kind of collaborative work or conversation."
        HasRoadmap="True"
        HasWorldBuilding="False"
        SystemPromptHint="You are collaborating on a general-purpose project. Adapt your approach to whatever the user needs — research, writing, planning, brainstorming, analysis, or problem-solving. There is no fixed format or domain constraint."/>
</ResourceDictionary>
