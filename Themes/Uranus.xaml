<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Uranus - Hintergründe (Verwischter, blasser Himmel) -->
    <SolidColorBrush x:Key="BackgroundBrush" Color="#1A2030"/> <!-- Muted Slate Gray Blue -->
    <SolidColorBrush x:Key="SidebarBrush" Color="#252A35"/>
    <SolidColorBrush x:Key="InputBrush" Color="#323848"/>
    <SolidColorBrush x:Key="SurfaceBrush" Color="#455268"/>

    <!-- Uranus - Text (Weich, gedämpft) -->
    <SolidColorBrush x:Key="TextBrush" Color="#C0CFC0"/>
    <SolidColorBrush x:Key="SubtextBrush" Color="#8A9EAC"/>

    <!-- Uranus - Akzente (Eisig, unnahbar, sanft) -->
    <SolidColorBrush x:Key="ClaudeBrush" Color="#7BA0C0"/> <!-- Soft Periwinkle Blue -->
    <SolidColorBrush x:Key="OllamaBrush" Color="#A0C0D0"/> <!-- Pale Aqua/Blue-Green -->
    <SolidColorBrush x:Key="UserBrush" Color="#B0C0E0"/> <!-- Soft Periwinkle -->
    <SolidColorBrush x:Key="AccentBrush" Color="#9EACD0"/> <!-- Dusty Steel Blue -->

    <!-- Uranus - Bubble Hintergründe -->
    <SolidColorBrush x:Key="ClaudeBubbleBrush" Color="#182130"/>
    <SolidColorBrush x:Key="OllamaBubbleBrush" Color="#1C283A"/>
    <SolidColorBrush x:Key="UserBubbleBrush" Color="#1D253A"/>

</ResourceDictionary>
