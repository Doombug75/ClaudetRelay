<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Leatherbound Green -->
    <!-- Chat-Fenster: altes Pergament  |  Rahmen: tiefes Jägergrün-Leder -->
    <SolidColorBrush x:Key="BackgroundBrush" Color="#F4E8CC"/> <!-- Gealtertes Pergament (Chat-Fläche) -->
    <SolidColorBrush x:Key="SidebarBrush"   Color="#1A3020"/> <!-- Tiefes Jägergrün-Leder -->
    <SolidColorBrush x:Key="InputBrush"     Color="#284030"/> <!-- Aufgehelltes Grün — Buttons, Karten -->
    <SolidColorBrush x:Key="SurfaceBrush"   Color="#345040"/> <!-- Leicht helleres Grün — Oberflächen -->

    <!-- Text: sehr dunkle Tinte auf Pergament — Blattgold auf Leder -->
    <SolidColorBrush x:Key="TextBrush"     Color="#0A1408"/> <!-- Fast schwarzes Dunkelgrün (Tinte auf Pergament) -->
    <SolidColorBrush x:Key="SubtextBrush"  Color="#D4AA3A"/> <!-- Blattgold (auf Leder-Bereichen) -->
    <SolidColorBrush x:Key="CardTextBrush"        Color="#D4AA3A"/> <!-- Blattgold auf Leder-Karten (Teilnehmer-Buttons) -->
    <SolidColorBrush x:Key="InputBackgroundBrush" Color="#F4E8CC"/> <!-- Pergament im Chat-Eingabefeld -->

    <!-- Akzente: Grün-Töne, aufgehellt — Messing, Blattwerk, botanisches Bestimmungsbuch -->
    <SolidColorBrush x:Key="ClaudeBrush"  Color="#3A7048"/> <!-- Helles Waldgrün -->
    <SolidColorBrush x:Key="OllamaBrush"  Color="#2A5835"/> <!-- Mittleres Dunkelgrün -->
    <SolidColorBrush x:Key="UserBrush"    Color="#4A8858"/> <!-- Aufgehelltes Grün-Highlight -->
    <SolidColorBrush x:Key="AccentBrush"  Color="#58A868"/> <!-- Lebhaftes Blattgrün -->

    <!-- Chat-Bubble-Hintergründe: Pergament mit leichtem grünen Hauch -->
    <SolidColorBrush x:Key="ClaudeBubbleBrush" Color="#EAE8D8"/> <!-- Pergament, grün getönt -->
    <SolidColorBrush x:Key="OllamaBubbleBrush" Color="#E8E4CC"/> <!-- Warmes gelbliches Pergament -->
    <SolidColorBrush x:Key="UserBubbleBrush"   Color="#F2EAD4"/> <!-- Cremiges Pergament -->

</ResourceDictionary>
