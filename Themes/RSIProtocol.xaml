<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Roberts Space Industries — "Delivering the Stars Since 2075"          -->
    <!-- Brand: deep RSI navy + white/silver + orange-gold accent               -->
    <!-- Cockpit displays: clean blue/white interface — Aurora, Constellation   -->

    <!-- Backgrounds — premium starship interior, dark navy bulkheads -->
    <SolidColorBrush x:Key="BackgroundBrush" Color="#080E1A"/> <!-- Deep RSI navy          -->
    <SolidColorBrush x:Key="SidebarBrush"    Color="#050912"/> <!-- Inner hull              -->
    <SolidColorBrush x:Key="InputBrush"      Color="#0F1C30"/> <!-- Panel recess            -->
    <SolidColorBrush x:Key="SurfaceBrush"    Color="#1A2E4A"/> <!-- Raised console surface  -->

    <!-- Text — clean, crisp, premium -->
    <SolidColorBrush x:Key="TextBrush"    Color="#E8F0F8"/> <!-- RSI clean white          -->
    <SolidColorBrush x:Key="SubtextBrush" Color="#4E6E98"/> <!-- Muted nav blue           -->

    <!-- Accents — RSI brand blue + orange-gold logo accent -->
    <SolidColorBrush x:Key="ClaudeBrush"  Color="#2878D8"/> <!-- RSI primary blue         -->
    <SolidColorBrush x:Key="OllamaBrush"  Color="#52A8E8"/> <!-- Secondary system blue    -->
    <SolidColorBrush x:Key="UserBrush"    Color="#88C0F0"/> <!-- Interface pale blue      -->
    <SolidColorBrush x:Key="AccentBrush"  Color="#D88020"/> <!-- RSI orange-gold logo accent -->

    <!-- Bubble backgrounds — cockpit display tints -->
    <SolidColorBrush x:Key="ClaudeBubbleBrush" Color="#0A1A30"/> <!-- Deep nav blue        -->
    <SolidColorBrush x:Key="OllamaBubbleBrush" Color="#081828"/> <!-- Darker system blue   -->
    <SolidColorBrush x:Key="UserBubbleBrush"   Color="#0A1620"/> <!-- Comms blue           -->

</ResourceDictionary>
