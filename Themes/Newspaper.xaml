<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Newspaper -->
    <!-- Pure black ink on white paper — greyscale only, no colour whatsoever -->
    <SolidColorBrush x:Key="BackgroundBrush" Color="#FFFFFF"/> <!-- White newsprint -->
    <SolidColorBrush x:Key="SidebarBrush"   Color="#EBEBEB"/> <!-- Light grey column margin -->
    <SolidColorBrush x:Key="InputBrush"     Color="#DCDCDC"/> <!-- Slightly darker grey — cards, buttons -->
    <SolidColorBrush x:Key="SurfaceBrush"   Color="#CCCCCC"/> <!-- Medium light grey — surfaces -->

    <!-- Text: near-black ink — grey captions -->
    <SolidColorBrush x:Key="TextBrush"    Color="#0A0A0A"/> <!-- Near-black ink -->
    <SolidColorBrush x:Key="SubtextBrush" Color="#606060"/> <!-- Medium grey — captions, timestamps -->

    <!-- Accents: greyscale only -->
    <SolidColorBrush x:Key="ClaudeBrush"  Color="#222222"/> <!-- Dark grey -->
    <SolidColorBrush x:Key="OllamaBrush"  Color="#444444"/> <!-- Medium dark grey -->
    <SolidColorBrush x:Key="UserBrush"    Color="#555555"/> <!-- Medium grey -->
    <SolidColorBrush x:Key="AccentBrush"  Color="#111111"/> <!-- Near-black highlight -->

    <!-- Chat bubbles: off-white paper shades -->
    <SolidColorBrush x:Key="ClaudeBubbleBrush" Color="#F2F2F2"/> <!-- Very light grey -->
    <SolidColorBrush x:Key="OllamaBubbleBrush" Color="#ECECEC"/> <!-- Slightly darker -->
    <SolidColorBrush x:Key="UserBubbleBrush"   Color="#F8F8F8"/> <!-- Near white -->

</ResourceDictionary>
