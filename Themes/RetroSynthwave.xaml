<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Retro Synthwave - Hintergründe -->
    <SolidColorBrush x:Key="BackgroundBrush" Color="#1A0033"/> <!-- Deep Purple -->
    <SolidColorBrush x:Key="SidebarBrush" Color="#2D0066"/>
    <SolidColorBrush x:Key="InputBrush" Color="#3A0077"/>
    <SolidColorBrush x:Key="SurfaceBrush" Color="#4B0099"/>

    <!-- Retro Synthwave - Text -->
    <SolidColorBrush x:Key="TextBrush" Color="#E0B0FF"/> <!-- Pale Lavender -->
    <SolidColorBrush x:Key="SubtextBrush" Color="#9370DB"/> <!-- Medium Purple -->

    <!-- Retro Synthwave - Akzente -->
    <SolidColorBrush x:Key="ClaudeBrush" Color="#FF00FF"/> <!-- Hot Pink Neon -->
    <SolidColorBrush x:Key="OllamaBrush" Color="#00FFFF"/> <!-- Cyan Neon -->
    <SolidColorBrush x:Key="UserBrush" Color="#FF69B4"/> <!-- Medium Pink -->
    <SolidColorBrush x:Key="AccentBrush" Color="#FFD700"/> <!-- Gold Pop -->

    <!-- Retro Synthwave - Bubble Hintergründe -->
    <SolidColorBrush x:Key="ClaudeBubbleBrush" Color="#100022"/>
    <SolidColorBrush x:Key="OllamaBubbleBrush" Color="#000033"/>
    <SolidColorBrush x:Key="UserBubbleBrush" Color="#000011"/>

</ResourceDictionary>


