<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Vault-Tec — "Securing Your Future Since 2021"                     -->
    <!-- Brand palette: Vault-Tec Cobalt Blue + Signature Gold Yellow      -->
    <!-- Deep vault-interior navy backgrounds, warm cream bureaucratic text -->

    <!-- Backgrounds — the inside of a vault -->
    <SolidColorBrush x:Key="BackgroundBrush" Color="#0B1422"/> <!-- Vault floor — near-black navy -->
    <SolidColorBrush x:Key="SidebarBrush"    Color="#080E18"/> <!-- Inner sanctum              -->
    <SolidColorBrush x:Key="InputBrush"      Color="#13213A"/> <!-- Control panel recess       -->
    <SolidColorBrush x:Key="SurfaceBrush"    Color="#1C3258"/> <!-- Raised panel / terminal    -->

    <!-- Text — Vault-Tec bureaucratic documentation -->
    <SolidColorBrush x:Key="TextBrush"    Color="#EDE5BF"/> <!-- Warm cream — printed forms  -->
    <SolidColorBrush x:Key="SubtextBrush" Color="#5A7898"/> <!-- Muted institutional blue    -->

    <!-- Accents — the two Vault-Tec brand colours -->
    <SolidColorBrush x:Key="ClaudeBrush"  Color="#FFD200"/> <!-- Vault-Tec Signature Yellow  -->
    <SolidColorBrush x:Key="OllamaBrush"  Color="#4E90D8"/> <!-- Vault-Tec Cobalt Blue       -->
    <SolidColorBrush x:Key="UserBrush"    Color="#8ABDE8"/> <!-- Terminal screen blue        -->
    <SolidColorBrush x:Key="AccentBrush"  Color="#F0AD00"/> <!-- Deep amber gold — warnings  -->

    <!-- Bubble backgrounds -->
    <SolidColorBrush x:Key="ClaudeBubbleBrush" Color="#1E1900"/> <!-- Dark warm — yellow tint  -->
    <SolidColorBrush x:Key="OllamaBubbleBrush" Color="#0C1C30"/> <!-- Dark cobalt              -->
    <SolidColorBrush x:Key="UserBubbleBrush"   Color="#0E1E34"/> <!-- Deep vault navy          -->

</ResourceDictionary>
