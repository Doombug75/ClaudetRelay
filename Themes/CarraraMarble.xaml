<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Carrara Marble - Hintergründe (Kühle, feine Steinstruktur) -->
    <SolidColorBrush x:Key="BackgroundBrush" Color="#F8F7F3"/> <!-- Off-White Cream -->
    <SolidColorBrush x:Key="SidebarBrush" Color="#EAECE5"/>
    <SolidColorBrush x:Key="InputBrush" Color="#E5E3E0"/>
    <SolidColorBrush x:Key="SurfaceBrush" Color="#DCD6C9"/>

    <!-- Carrara Marble - Text (Klar, edel) -->
    <SolidColorBrush x:Key="TextBrush" Color="#333333"/>
    <SolidColorBrush x:Key="SubtextBrush" Color="#6D6863"/>

    <!-- Carrara Marble - Akzente (Patina, Gold, Grünadern) -->
    <SolidColorBrush x:Key="ClaudeBrush" Color="#7C6A8F"/> <!-- Dusty Lavender/Grau -->
    <SolidColorBrush x:Key="OllamaBrush" Color="#779966"/> <!-- Soft Moss Green/Jade -->
    <SolidColorBrush x:Key="UserBrush" Color="#6B8E86"/> <!-- Patina Blue-Gray -->
    <SolidColorBrush x:Key="AccentBrush" Color="#B8860B"/> <!-- Aged Gold/Bronze -->

    <!-- Carrara Marble - Bubble Hintergründe -->
    <SolidColorBrush x:Key="ClaudeBubbleBrush" Color="#E8E3E0"/>
    <SolidColorBrush x:Key="OllamaBubbleBrush" Color="#E5E8E2"/>
    <SolidColorBrush x:Key="UserBubbleBrush" Color="#EAECE5"/>

</ResourceDictionary>
