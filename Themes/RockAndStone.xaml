<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Rock and Stone! (Deep Rock Galactic) -->
    <!-- Chat-Fenster: tiefer Minenschacht  |  Rahmen: rohes Gestein -->
    <SolidColorBrush x:Key="BackgroundBrush" Color="#1A1814"/> <!-- Dunkles Höhlengestein -->
    <SolidColorBrush x:Key="SidebarBrush"   Color="#0E0C0A"/> <!-- Tiefer Minenschacht -->
    <SolidColorBrush x:Key="InputBrush"     Color="#2A2418"/> <!-- Rauer Steinboden -->
    <SolidColorBrush x:Key="SurfaceBrush"   Color="#342C1E"/> <!-- Hellere Gesteinsschicht -->

    <!-- Text: Warmes Bergleuchten — Minenlampe -->
    <SolidColorBrush x:Key="TextBrush"    Color="#E8D098"/> <!-- Warmes Bernstein / Minenlampen-Glühen -->
    <SolidColorBrush x:Key="SubtextBrush" Color="#806040"/> <!-- Gedämpftes Höhlenbraun -->

    <!-- Akzente: Warnlampe Orange, Scout-Grün, Nitra-Rot -->
    <SolidColorBrush x:Key="ClaudeBrush"  Color="#D08020"/> <!-- Warnlampe Orange / Mining Lamp -->
    <SolidColorBrush x:Key="OllamaBrush"  Color="#A06018"/> <!-- Tiefes Bernstein -->
    <SolidColorBrush x:Key="UserBrush"    Color="#488848"/> <!-- Scout-Grün / Leaf Lover's Special -->
    <SolidColorBrush x:Key="AccentBrush"  Color="#F0A020"/> <!-- ROCK AND STONE! Hazard-Gelb -->

    <!-- Chat-Bubble-Hintergründe: dunkle Höhlentaschen -->
    <SolidColorBrush x:Key="ClaudeBubbleBrush" Color="#221C10"/> <!-- Dunkle Höhlennische -->
    <SolidColorBrush x:Key="OllamaBubbleBrush" Color="#1E1A0E"/> <!-- Tiefes Gestein -->
    <SolidColorBrush x:Key="UserBubbleBrush"   Color="#24200E"/> <!-- Warme Höhlenwand -->

</ResourceDictionary>
