<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Drake Interplanetary — "Affordable Ships for the Working Man"           -->
    <!-- Brand: industrial signature orange on near-black — rough, no-frills    -->
    <!-- Cockpit displays: orange/amber on grime-dark — Caterpillar, Cutlass    -->

    <!-- Backgrounds — engine room grime, welded steel, industrial dark -->
    <SolidColorBrush x:Key="BackgroundBrush" Color="#0C0A07"/> <!-- Engine grease black     -->
    <SolidColorBrush x:Key="SidebarBrush"    Color="#080705"/> <!-- Void black              -->
    <SolidColorBrush x:Key="InputBrush"      Color="#181410"/> <!-- Worn panel recess       -->
    <SolidColorBrush x:Key="SurfaceBrush"    Color="#2A2218"/> <!-- Scratched metal surface -->

    <!-- Text — worn, weathered, barely maintained -->
    <SolidColorBrush x:Key="TextBrush"    Color="#D8C8A0"/> <!-- Worn paper / paint       -->
    <SolidColorBrush x:Key="SubtextBrush" Color="#786850"/> <!-- Rust-stained grey        -->

    <!-- Accents — Drake signature orange, industrial amber -->
    <SolidColorBrush x:Key="ClaudeBrush"  Color="#E86818"/> <!-- Drake signature orange   -->
    <SolidColorBrush x:Key="OllamaBrush"  Color="#C05018"/> <!-- Darker industrial orange -->
    <SolidColorBrush x:Key="UserBrush"    Color="#A87830"/> <!-- Brass/bronze             -->
    <SolidColorBrush x:Key="AccentBrush"  Color="#F08030"/> <!-- Bright caution orange    -->

    <!-- Bubble backgrounds — battered cockpit display tints -->
    <SolidColorBrush x:Key="ClaudeBubbleBrush" Color="#1C1008"/> <!-- Dark orange tint     -->
    <SolidColorBrush x:Key="OllamaBubbleBrush" Color="#180C04"/> <!-- Deeper orange-brown  -->
    <SolidColorBrush x:Key="UserBubbleBrush"   Color="#1A1208"/> <!-- Dark bronze tint     -->

</ResourceDictionary>
