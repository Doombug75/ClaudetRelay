<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Leatherbound Blue -->
    <!-- Chat-Fenster: altes Pergament  |  Rahmen: tiefes Mitternachtsblau-Leder -->
    <SolidColorBrush x:Key="BackgroundBrush" Color="#F4E8CC"/> <!-- Gealtertes Pergament (Chat-Fläche) -->
    <SolidColorBrush x:Key="SidebarBrush"   Color="#1A2840"/> <!-- Tiefes Mitternachtsblau-Leder -->
    <SolidColorBrush x:Key="InputBrush"     Color="#283858"/> <!-- Aufgehelltes Navy — Buttons, Karten -->
    <SolidColorBrush x:Key="SurfaceBrush"   Color="#304470"/> <!-- Leicht helleres Navy — Oberflächen -->

    <!-- Text: tiefdunkle Tinte auf Pergament — Blattgold auf Leder -->
    <SolidColorBrush x:Key="TextBrush"     Color="#08101E"/> <!-- Sehr dunkles Tintenblau (auf Pergament) -->
    <SolidColorBrush x:Key="SubtextBrush"  Color="#D4AA3A"/> <!-- Blattgold (auf Leder-Bereichen) -->
    <SolidColorBrush x:Key="CardTextBrush"        Color="#D4AA3A"/> <!-- Blattgold auf Leder-Karten (Teilnehmer-Buttons) -->
    <SolidColorBrush x:Key="InputBackgroundBrush" Color="#F4E8CC"/> <!-- Pergament im Chat-Eingabefeld -->

    <!-- Akzente: Navy-Töne, leicht aufgehellt — wie Silber- und Goldprägung auf blauem Leder -->
    <SolidColorBrush x:Key="ClaudeBrush"  Color="#3C60A0"/> <!-- Helles Tintenblau -->
    <SolidColorBrush x:Key="OllamaBrush"  Color="#2A4878"/> <!-- Mittleres Navy -->
    <SolidColorBrush x:Key="UserBrush"    Color="#4870C0"/> <!-- Aufgehelltes Blau-Highlight -->
    <SolidColorBrush x:Key="AccentBrush"  Color="#5888D8"/> <!-- Lebhaftes Stahlblau -->

    <!-- Chat-Bubble-Hintergründe: Pergament mit leichtem blauen Hauch -->
    <SolidColorBrush x:Key="ClaudeBubbleBrush" Color="#EAE4D8"/> <!-- Pergament, kühl getönt -->
    <SolidColorBrush x:Key="OllamaBubbleBrush" Color="#E8DCC0"/> <!-- Warmes Pergament -->
    <SolidColorBrush x:Key="UserBubbleBrush"   Color="#F2EAD4"/> <!-- Cremiges Pergament -->

</ResourceDictionary>
