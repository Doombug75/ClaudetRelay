<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Slime Pop Malfunction - Hintergründe (Synthetisch, Überladen) -->
    <SolidColorBrush x:Key="BackgroundBrush" Color="#080010"/> <!-- Toxic Black/Vacuum -->
    <SolidColorBrush x:Key="SidebarBrush" Color="#120318"/>
    <SolidColorBrush x:Key="InputBrush" Color="#1D0924"/>
    <SolidColorBrush x:Key="SurfaceBrush" Color="#280F36"/>

    <!-- Slime Pop Malfunction - Text (Grelle, künstliche Textur) -->
    <SolidColorBrush x:Key="TextBrush" Color="#EAE0FF"/> <!-- Pale Lavender Glow -->
    <SolidColorBrush x:Key="SubtextBrush" Color="#9980C0"/>

    <!-- Slime Pop Malfunction - Akzente (Die psychedelische Chemie) -->
    <SolidColorBrush x:Key="ClaudeBrush" Color="#FF33FF"/> <!-- Electric Bubblegum Pink -->
    <SolidColorBrush x:Key="OllamaBrush" Color="#CCFF33"/> <!-- Highly Fluorescent Chartreuse -->
    <SolidColorBrush x:Key="UserBrush" Color="#66FFEE"/> <!-- Intense Cyan Neon -->
    <SolidColorBrush x:Key="AccentBrush" Color="#FFCC00"/> <!-- Warning Lemon Yellow -->

    <!-- Slime Pop Malfunction - Bubble Hintergründe -->
    <SolidColorBrush x:Key="ClaudeBubbleBrush" Color="#10040C"/>
    <SolidColorBrush x:Key="OllamaBubbleBrush" Color="#061005"/>
    <SolidColorBrush x:Key="UserBubbleBrush" Color="#09050D"/>

</ResourceDictionary>




