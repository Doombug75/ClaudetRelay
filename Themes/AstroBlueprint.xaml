<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Astro Blueprint - Hintergründe -->
    <SolidColorBrush x:Key="BackgroundBrush" Color="#F0EAD6"/> <!-- Aged Paper Cream -->
    <SolidColorBrush x:Key="SidebarBrush" Color="#DDEECC"/> <!-- Light Gray Plan Background -->
    <SolidColorBrush x:Key="InputBrush" Color="#E0E7D2"/>
    <SolidColorBrush x:Key="SurfaceBrush" Color="#C3D2BC"/>

    <!-- Astro Blueprint - Text -->
    <SolidColorBrush x:Key="TextBrush" Color="#333333"/> <!-- Charcoal Text -->
    <SolidColorBrush x:Key="SubtextBrush" Color="#666666"/>

    <!-- Astro Blueprint - Akzente -->
    <SolidColorBrush x:Key="ClaudeBrush" Color="#A52A2A"/> <!-- Sepia/Copper Brown -->
    <SolidColorBrush x:Key="OllamaBrush" Color="#228B22"/> <!-- Forest Green Marker -->
    <SolidColorBrush x:Key="UserBrush" Color="#0000CD"/> <!-- Classic Medium Blue -->
    <SolidColorBrush x:Key="AccentBrush" Color="#FFD700"/> <!-- Highlight Gold -->

    <!-- Astro Blueprint - Bubble Hintergründe -->
    <SolidColorBrush x:Key="ClaudeBubbleBrush" Color="#E2D5C6"/>
    <SolidColorBrush x:Key="OllamaBubbleBrush" Color="#D2EAD2"/>
    <SolidColorBrush x:Key="UserBubbleBrush" Color="#CCE0FF"/>

</ResourceDictionary>



