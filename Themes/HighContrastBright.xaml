<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- High Contrast Bright -->
    <!-- Pure white background with maximum contrast — designed for visual accessibility (WCAG AAA) -->
    <!-- Entire UI stays light so pure black TextBrush is readable everywhere -->
    <SolidColorBrush x:Key="BackgroundBrush" Color="#FFFFFF"/> <!-- Pure white -->
    <SolidColorBrush x:Key="SidebarBrush"   Color="#F0F0F0"/> <!-- Very light grey — stays readable with black text -->
    <SolidColorBrush x:Key="InputBrush"     Color="#D8D8D8"/> <!-- Light grey — clearly distinct from background -->
    <SolidColorBrush x:Key="SurfaceBrush"   Color="#C0C0C0"/> <!-- Medium light grey -->

    <!-- Text: pure black on white — maximum contrast -->
    <SolidColorBrush x:Key="TextBrush"    Color="#000000"/> <!-- Pure black -->
    <SolidColorBrush x:Key="SubtextBrush" Color="#404040"/> <!-- Dark grey — readable on all light surfaces -->

    <!-- Accents: strong, saturated dark colours — high contrast against light backgrounds -->
    <SolidColorBrush x:Key="ClaudeBrush"  Color="#0000CC"/> <!-- Strong blue -->
    <SolidColorBrush x:Key="OllamaBrush"  Color="#006600"/> <!-- Strong green -->
    <SolidColorBrush x:Key="UserBrush"    Color="#880000"/> <!-- Strong red -->
    <SolidColorBrush x:Key="AccentBrush"  Color="#0000EE"/> <!-- Pure blue highlight -->

    <!-- Chat bubbles: pale tints for visual differentiation without sacrificing readability -->
    <SolidColorBrush x:Key="ClaudeBubbleBrush" Color="#E0E4FF"/> <!-- Pale blue -->
    <SolidColorBrush x:Key="OllamaBubbleBrush" Color="#E0F4E0"/> <!-- Pale green -->
    <SolidColorBrush x:Key="UserBubbleBrush"   Color="#FFE8E8"/> <!-- Pale red -->

</ResourceDictionary>
