<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- New California Republic — "Bear the Weight"                               -->
    <!-- Brand: desert tan, NCR brass Ranger badge, two-headed bear flag red       -->
    <!-- Aesthetic: dusty wasteland parchment, Mojave heat, government khaki       -->

    <!-- Backgrounds — dark desert grime, dried wasteland earth -->
    <SolidColorBrush x:Key="BackgroundBrush" Color="#100C08"/> <!-- Dark desert grime        -->
    <SolidColorBrush x:Key="SidebarBrush"    Color="#0C0906"/> <!-- Deeper dust dark         -->
    <SolidColorBrush x:Key="InputBrush"      Color="#181210"/> <!-- Panel recess, dirt floor -->
    <SolidColorBrush x:Key="SurfaceBrush"    Color="#241A14"/> <!-- Weathered console surface-->

    <!-- Text — sun-bleached parchment, NCR bureaucratic paper -->
    <SolidColorBrush x:Key="TextBrush"    Color="#D8C89C"/> <!-- Desert parchment          -->
    <SolidColorBrush x:Key="SubtextBrush" Color="#806848"/> <!-- Muted Mojave dust         -->

    <!-- Accents — NCR brass badge, bear flag red, ranger tan -->
    <SolidColorBrush x:Key="ClaudeBrush"  Color="#C8901C"/> <!-- NCR brass — Ranger badge  -->
    <SolidColorBrush x:Key="OllamaBrush"  Color="#8C6828"/> <!-- NCR khaki — desert tan    -->
    <SolidColorBrush x:Key="UserBrush"    Color="#A07848"/> <!-- Settler's worn leather    -->
    <SolidColorBrush x:Key="AccentBrush"  Color="#C43020"/> <!-- NCR flag red — the Bear   -->

    <!-- Bubble backgrounds — dusty terminal tints, NCR field dispatch -->
    <SolidColorBrush x:Key="ClaudeBubbleBrush" Color="#1A1208"/> <!-- Dark brass tint       -->
    <SolidColorBrush x:Key="OllamaBubbleBrush" Color="#160E06"/> <!-- Dark desert earth     -->
    <SolidColorBrush x:Key="UserBubbleBrush"   Color="#140E08"/> <!-- Dry dust dark         -->

</ResourceDictionary>
