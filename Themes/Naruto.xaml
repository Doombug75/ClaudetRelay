<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Naruto — "Believe It! / Dattebayo!"                                       -->
    <!-- Brand: orange jumpsuit, Leaf Village headband blue, Nine-Tails red        -->
    <!-- Aesthetic: Hidden Leaf night mission, Rasengan glow, Kyuubi chakra flare  -->

    <!-- Backgrounds — Hidden Leaf night, mission briefing dark -->
    <SolidColorBrush x:Key="BackgroundBrush" Color="#0A0C10"/> <!-- Night mission dark       -->
    <SolidColorBrush x:Key="SidebarBrush"    Color="#07090C"/> <!-- Deeper forest night      -->
    <SolidColorBrush x:Key="InputBrush"      Color="#101420"/> <!-- Panel recess             -->
    <SolidColorBrush x:Key="SurfaceBrush"    Color="#181E2C"/> <!-- Hokage office surface    -->

    <!-- Text — warm scroll parchment, jutsu scroll -->
    <SolidColorBrush x:Key="TextBrush"    Color="#E0D8C0"/> <!-- Jutsu scroll parchment   -->
    <SolidColorBrush x:Key="SubtextBrush" Color="#608098"/> <!-- Muted Leaf-blue           -->

    <!-- Accents — orange jumpsuit, Leaf Village blue, Nine-Tails red -->
    <SolidColorBrush x:Key="ClaudeBrush"  Color="#E07020"/> <!-- Naruto orange — "Dattebayo!"-->
    <SolidColorBrush x:Key="OllamaBrush"  Color="#2858B0"/> <!-- Leaf Village headband    -->
    <SolidColorBrush x:Key="UserBrush"    Color="#4080D8"/> <!-- Konoha mission blue      -->
    <SolidColorBrush x:Key="AccentBrush"  Color="#E03820"/> <!-- Nine-Tails Kyuubi red    -->

    <!-- Bubble backgrounds — chakra display tints -->
    <SolidColorBrush x:Key="ClaudeBubbleBrush" Color="#180C04"/> <!-- Dark orange chakra    -->
    <SolidColorBrush x:Key="OllamaBubbleBrush" Color="#080C18"/> <!-- Leaf Village dark     -->
    <SolidColorBrush x:Key="UserBubbleBrush"   Color="#080C18"/> <!-- Mission blue dark     -->

</ResourceDictionary>
