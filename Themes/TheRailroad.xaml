<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- The Railroad — "FREEDOM Regardless of the Cost"                           -->
    <!-- Brand: underground red, worn leather, dead-drop covert ops                -->
    <!-- Aesthetic: safehouse peeling paint, coded messages, synth liberation      -->

    <!-- Backgrounds — underground cellar, safehouse dark -->
    <SolidColorBrush x:Key="BackgroundBrush" Color="#100A08"/> <!-- Underground cellar dark  -->
    <SolidColorBrush x:Key="SidebarBrush"    Color="#0C0806"/> <!-- Deeper safehouse         -->
    <SolidColorBrush x:Key="InputBrush"      Color="#180E0C"/> <!-- Panel recess             -->
    <SolidColorBrush x:Key="SurfaceBrush"    Color="#241410"/> <!-- Worn console surface     -->

    <!-- Text — worn parchment, dead-drop paper -->
    <SolidColorBrush x:Key="TextBrush"    Color="#D0C0A4"/> <!-- Dead-drop parchment      -->
    <SolidColorBrush x:Key="SubtextBrush" Color="#705040"/> <!-- Muted leather-rust       -->

    <!-- Accents — Railroad red, aged leather, covert signal -->
    <SolidColorBrush x:Key="ClaudeBrush"  Color="#C82818"/> <!-- Railroad red — "FREEDOM" -->
    <SolidColorBrush x:Key="OllamaBrush"  Color="#886028"/> <!-- Aged leather brown       -->
    <SolidColorBrush x:Key="UserBrush"    Color="#A05040"/> <!-- Faded covert ops         -->
    <SolidColorBrush x:Key="AccentBrush"  Color="#E03428"/> <!-- Bright red — rally signal-->

    <!-- Bubble backgrounds — safehouse display tints -->
    <SolidColorBrush x:Key="ClaudeBubbleBrush" Color="#180A08"/> <!-- Deep red              -->
    <SolidColorBrush x:Key="OllamaBubbleBrush" Color="#161008"/> <!-- Dark leather          -->
    <SolidColorBrush x:Key="UserBubbleBrush"   Color="#160C0A"/> <!-- Covert dark           -->

</ResourceDictionary>
