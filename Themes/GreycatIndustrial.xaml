<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Greycat Industrial — "Built for the Surface"                              -->
    <!-- Brand: safety yellow, machine grey, warning stripe — ROC, PTV, STV       -->
    <!-- Cockpit displays: yellow-on-black cab instruments, construction site HUD  -->

    <!-- Backgrounds — machine floor dark, garage black -->
    <SolidColorBrush x:Key="BackgroundBrush" Color="#0A0A08"/> <!-- Machine floor dark       -->
    <SolidColorBrush x:Key="SidebarBrush"    Color="#070708"/> <!-- Garage deep dark         -->
    <SolidColorBrush x:Key="InputBrush"      Color="#100E0C"/> <!-- Panel recess             -->
    <SolidColorBrush x:Key="SurfaceBrush"    Color="#181610"/> <!-- Console surface          -->

    <!-- Text — grey-warm white, operator manual -->
    <SolidColorBrush x:Key="TextBrush"    Color="#D0CCB0"/> <!-- Grey-warm white           -->
    <SolidColorBrush x:Key="SubtextBrush" Color="#708068"/> <!-- Muted industrial          -->

    <!-- Accents — Greycat safety yellow, machine grey, warning stripe -->
    <SolidColorBrush x:Key="ClaudeBrush"  Color="#C8B820"/> <!-- Greycat safety yellow     -->
    <SolidColorBrush x:Key="OllamaBrush"  Color="#888880"/> <!-- Industrial machine grey   -->
    <SolidColorBrush x:Key="UserBrush"    Color="#A8A898"/> <!-- Muted grey interface      -->
    <SolidColorBrush x:Key="AccentBrush"  Color="#E0D030"/> <!-- Bright warning stripe     -->

    <!-- Bubble backgrounds — cab instrument tints -->
    <SolidColorBrush x:Key="ClaudeBubbleBrush" Color="#121008"/> <!-- Dark yellow tint      -->
    <SolidColorBrush x:Key="OllamaBubbleBrush" Color="#101010"/> <!-- Machine grey dark     -->
    <SolidColorBrush x:Key="UserBubbleBrush"   Color="#101008"/> <!-- Industrial dark       -->

</ResourceDictionary>
