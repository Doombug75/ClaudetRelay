<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Consolidated Outland — "Affordable. Reliable. Yours."                    -->
    <!-- Brand: CNOU orange-tan, roughneck earth, budget accessible — Mustang     -->
    <!-- Cockpit displays: warm orange on dark tan — Pioneer, Mustang Alpha/Beta  -->

    <!-- Backgrounds — roughneck dark, dirt floor -->
    <SolidColorBrush x:Key="BackgroundBrush" Color="#100C08"/> <!-- Roughneck dark earth     -->
    <SolidColorBrush x:Key="SidebarBrush"    Color="#0C0906"/> <!-- Deeper dust dark         -->
    <SolidColorBrush x:Key="InputBrush"      Color="#181210"/> <!-- Panel recess             -->
    <SolidColorBrush x:Key="SurfaceBrush"    Color="#241A14"/> <!-- Worn console surface     -->

    <!-- Text — tan-warm white, field manual -->
    <SolidColorBrush x:Key="TextBrush"    Color="#D8C8A4"/> <!-- Tan-warm white            -->
    <SolidColorBrush x:Key="SubtextBrush" Color="#806848"/> <!-- Muted dusty brown         -->

    <!-- Accents — CNOU orange, earth secondary, sandy tan -->
    <SolidColorBrush x:Key="ClaudeBrush"  Color="#D07828"/> <!-- CNOU signature orange     -->
    <SolidColorBrush x:Key="OllamaBrush"  Color="#A06028"/> <!-- Secondary earth orange    -->
    <SolidColorBrush x:Key="UserBrush"    Color="#B09870"/> <!-- Sandy field tan           -->
    <SolidColorBrush x:Key="AccentBrush"  Color="#E89030"/> <!-- Bright CNOU orange        -->

    <!-- Bubble backgrounds — budget display tints -->
    <SolidColorBrush x:Key="ClaudeBubbleBrush" Color="#181008"/> <!-- Dark orange tint      -->
    <SolidColorBrush x:Key="OllamaBubbleBrush" Color="#160E06"/> <!-- Earth dark            -->
    <SolidColorBrush x:Key="UserBubbleBrush"   Color="#160E0A"/> <!-- Sandy dark            -->

</ResourceDictionary>
