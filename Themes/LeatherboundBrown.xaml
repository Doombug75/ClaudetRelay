<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Leatherbound Brown -->
    <!-- Chat-Fenster: altes Pergament  |  Rahmen: sattes Sattelbraun-Leder -->
    <SolidColorBrush x:Key="BackgroundBrush" Color="#F4E8CC"/> <!-- Gealtertes Pergament (Chat-Fläche) -->
    <SolidColorBrush x:Key="SidebarBrush"   Color="#3A1E0C"/> <!-- Sattes Sattelbraun-Leder -->
    <SolidColorBrush x:Key="InputBrush"     Color="#552A12"/> <!-- Aufgehelltes Braun — Buttons, Karten -->
    <SolidColorBrush x:Key="SurfaceBrush"   Color="#6A3518"/> <!-- Leicht helleres Braun — Oberflächen -->

    <!-- Text: dunkle Sepia-Tinte auf Pergament — Blattgold auf Leder -->
    <SolidColorBrush x:Key="TextBrush"     Color="#1A0808"/> <!-- Dunkle Sepia-Tinte (auf Pergament) -->
    <SolidColorBrush x:Key="SubtextBrush"  Color="#D4AA3A"/> <!-- Blattgold (auf Leder-Bereichen) -->
    <SolidColorBrush x:Key="CardTextBrush"        Color="#D4AA3A"/> <!-- Blattgold auf Leder-Karten (Teilnehmer-Buttons) -->
    <SolidColorBrush x:Key="InputBackgroundBrush" Color="#F4E8CC"/> <!-- Pergament im Chat-Eingabefeld -->

    <!-- Akzente: Braun-Töne, aufgehellt — Kupfer, Messing, Sattelnieten -->
    <SolidColorBrush x:Key="ClaudeBrush"  Color="#8A4A20"/> <!-- Helles Sattelbraun -->
    <SolidColorBrush x:Key="OllamaBrush"  Color="#6A3818"/> <!-- Mittleres Dunkelbraun -->
    <SolidColorBrush x:Key="UserBrush"    Color="#A86030"/> <!-- Aufgehelltes Kupfer-Highlight -->
    <SolidColorBrush x:Key="AccentBrush"  Color="#C07838"/> <!-- Lebhaftes Bernstein/Kupfer -->

    <!-- Chat-Bubble-Hintergründe: warme Pergament-Variationen -->
    <SolidColorBrush x:Key="ClaudeBubbleBrush" Color="#EDE4C8"/> <!-- Warmes Amber-Pergament -->
    <SolidColorBrush x:Key="OllamaBubbleBrush" Color="#E8DCBC"/> <!-- Leicht getöntes Pergament -->
    <SolidColorBrush x:Key="UserBubbleBrush"   Color="#F2EAD4"/> <!-- Cremiges Pergament -->

</ResourceDictionary>
