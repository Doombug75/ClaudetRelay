<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Brotherhood of Steel — "Ad Victoriam"                                  -->
    <!-- Brand: dark steel grey + Brotherhood gold/yellow — power armor, order  -->
    <!-- The BoS logo is gold on grey; terminals glow gold on black steel        -->

    <!-- Backgrounds — bunker steel, dark grey like Power Armor plating -->
    <SolidColorBrush x:Key="BackgroundBrush" Color="#0C0E12"/> <!-- Dark steel plate        -->
    <SolidColorBrush x:Key="SidebarBrush"    Color="#080A0E"/> <!-- Bunker inner wall       -->
    <SolidColorBrush x:Key="InputBrush"      Color="#141820"/> <!-- Panel recess            -->
    <SolidColorBrush x:Key="SurfaceBrush"    Color="#202830"/> <!-- Console steel surface   -->

    <!-- Text — cold, authoritative, Brotherhood standard -->
    <SolidColorBrush x:Key="TextBrush"    Color="#D8D0B8"/> <!-- Warm steel white         -->
    <SolidColorBrush x:Key="SubtextBrush" Color="#587080"/> <!-- Muted tactical grey      -->

    <!-- Accents — Brotherhood gold + steel blue -->
    <SolidColorBrush x:Key="ClaudeBrush"  Color="#C8A020"/> <!-- Brotherhood gold — cog   -->
    <SolidColorBrush x:Key="OllamaBrush"  Color="#5880A0"/> <!-- Steel blue — tech        -->
    <SolidColorBrush x:Key="UserBrush"    Color="#98B0C8"/> <!-- Cold armour grey-blue    -->
    <SolidColorBrush x:Key="AccentBrush"  Color="#E0B828"/> <!-- Bright gold — "Ad Victoriam" -->

    <!-- Bubble backgrounds — terminal screen tints -->
    <SolidColorBrush x:Key="ClaudeBubbleBrush" Color="#1C1600"/> <!-- Dark gold tint        -->
    <SolidColorBrush x:Key="OllamaBubbleBrush" Color="#0C1420"/> <!-- Dark steel blue       -->
    <SolidColorBrush x:Key="UserBubbleBrush"   Color="#0E1420"/> <!-- Cold armour dark      -->

</ResourceDictionary>
