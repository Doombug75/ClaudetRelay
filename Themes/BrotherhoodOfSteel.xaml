<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Brotherhood of Steel - Hintergründe (Stahl, Beton, Ordnung) -->
    <SolidColorBrush x:Key="BackgroundBrush" Color="#101418"/> <!-- Deep Matte Charcoal -->
    <SolidColorBrush x:Key="SidebarBrush" Color="#1A2025"/>
    <SolidColorBrush x:Key="InputBrush" Color="#252B35"/>
    <SolidColorBrush x:Key="SurfaceBrush" Color="#3A4550"/>

    <!-- Brotherhood of Steel - Text (Kalt, stahlartig) -->
    <SolidColorBrush x:Key="TextBrush" Color="#DCDFE5"/>
    <SolidColorBrush x:Key="SubtextBrush" Color="#9CADBC"/>

    <!-- Brotherhood of Steel - Akzente (Militärisch, elektrisch, stahlblau) -->
    <SolidColorBrush x:Key="ClaudeBrush" Color="#4A699C"/> <!-- Authority Blue -->
    <SolidColorBrush x:Key="OllamaBrush" Color="#55A066"/> <!-- Military Olive Green -->
    <SolidColorBrush x:Key="UserBrush" Color="#8EA7D3"/> <!-- Assigned Duty Blue -->
    <SolidColorBrush x:Key="AccentBrush" Color="#A03333"/> <!-- Warning Crimson (Urgency) -->

    <!-- Brotherhood of Steel - Bubble Hintergründe -->
    <SolidColorBrush x:Key="ClaudeBubbleBrush" Color="#1C212B"/>
    <SolidColorBrush x:Key="OllamaBubbleBrush" Color="#13181C"/>
    <SolidColorBrush x:Key="UserBubbleBrush" Color="#1B2430"/>

</ResourceDictionary>





