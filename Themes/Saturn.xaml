<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Saturn - Hintergründe (Kühler, leer, kosmisch) -->
    <SolidColorBrush x:Key="BackgroundBrush" Color="#050810"/> <!-- Deep Midnight Blue/Black -->
    <SolidColorBrush x:Key="SidebarBrush" Color="#0A0D15"/>
    <SolidColorBrush x:Key="InputBrush" Color="#121822"/>
    <SolidColorBrush x:Key="SurfaceBrush" Color="#1E2535"/>

    <!-- Saturn - Text (Kaltes, präzises Licht) -->
    <SolidColorBrush x:Key="TextBrush" Color="#C0D0FF"/>
    <SolidColorBrush x:Key="SubtextBrush" Color="#8090C0"/>

    <!-- Saturn - Akzente (Eis, Kristall, kühler Glanz) -->
    <SolidColorBrush x:Key="ClaudeBrush" Color="#80AFFF"/> <!-- Icy Lavender Blue -->
    <SolidColorBrush x:Key="OllamaBrush" Color="#A3CCFF"/> <!-- Pale Sky Blue (Ice Glow) -->
    <SolidColorBrush x:Key="UserBrush" Color="#B0C0E0"/> <!-- Soft Silver-Blue -->
    <SolidColorBrush x:Key="AccentBrush" Color="#A0A0C0"/> <!-- Crystal Blue/Lavender -->

    <!-- Saturn - Bubble Hintergründe -->
    <SolidColorBrush x:Key="ClaudeBubbleBrush" Color="#080B10"/>
    <SolidColorBrush x:Key="OllamaBubbleBrush" Color="#0A141C"/>
    <SolidColorBrush x:Key="UserBubbleBrush" Color="#111622"/>

</ResourceDictionary>
