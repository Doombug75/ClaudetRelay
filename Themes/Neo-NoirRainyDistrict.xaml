<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Neo-Noir Rainy District - Hintergründe (Feucht, dunkel, reflektierend) -->
    <SolidColorBrush x:Key="BackgroundBrush" Color="#0A0810"/> <!-- Deep Twilight Blue/Black -->
    <SolidColorBrush x:Key="SidebarBrush" Color="#15121A"/>
    <SolidColorBrush x:Key="InputBrush" Color="#1D1824"/>
    <SolidColorBrush x:Key="SurfaceBrush" Color="#282030"/>

    <!-- Neo-Noir Rainy District - Text (Verwaschenes, künstliches Licht) -->
    <SolidColorBrush x:Key="TextBrush" Color="#DDE0FF"/>
    <SolidColorBrush x:Key="SubtextBrush" Color="#A0A5C0"/>

    <!-- Neo-Noir Rainy District - Akzente (Neon-Leuchtreffekte, elektrische Spannung) -->
    <SolidColorBrush x:Key="ClaudeBrush" Color="#66CCFF"/> <!-- Bright Cyan Neon (Hauptsignal) -->
    <SolidColorBrush x:Key="OllamaBrush" Color="#FF66FF"/> <!-- Magenta/Electric Pink (Gefahr/Hacking) -->
    <SolidColorBrush x:Key="UserBrush" Color="#99CCFF"/> <!-- Soft Blue Glow (Normaler Signalfluss) -->
    <SolidColorBrush x:Key="AccentBrush" Color="#FF9900"/> <!-- Orange Warning Light (Signal) -->

    <!-- Neo-Noir Rainy District - Bubble Hintergründe -->
    <SolidColorBrush x:Key="ClaudeBubbleBrush" Color="#0A0510"/>
    <SolidColorBrush x:Key="OllamaBubbleBrush" Color="#040B0F"/>
    <SolidColorBrush x:Key="UserBubbleBrush" Color="#070A12"/>

</ResourceDictionary>
