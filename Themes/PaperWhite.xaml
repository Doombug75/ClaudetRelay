<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- PaperWhite -->
    <!-- Warm e-reader white — easy on the eyes for long sessions -->
    <SolidColorBrush x:Key="BackgroundBrush" Color="#F8F4EE"/> <!-- Warm white paper -->
    <SolidColorBrush x:Key="SidebarBrush"   Color="#EDE8DF"/> <!-- Warm light beige -->
    <SolidColorBrush x:Key="InputBrush"     Color="#E0D8CC"/> <!-- Slightly darker warm grey -->
    <SolidColorBrush x:Key="SurfaceBrush"   Color="#D4CBBF"/> <!-- Medium warm grey-beige -->

    <!-- Text: warm near-black — like sepia ink on paper -->
    <SolidColorBrush x:Key="TextBrush"    Color="#1C1510"/> <!-- Warm near-black -->
    <SolidColorBrush x:Key="SubtextBrush" Color="#7A6E60"/> <!-- Warm medium grey -->

    <!-- Accents: muted, low-saturation — nothing distracting -->
    <SolidColorBrush x:Key="ClaudeBrush"  Color="#5570A0"/> <!-- Muted slate blue -->
    <SolidColorBrush x:Key="OllamaBrush"  Color="#508068"/> <!-- Muted sage green -->
    <SolidColorBrush x:Key="UserBrush"    Color="#906040"/> <!-- Muted warm brown -->
    <SolidColorBrush x:Key="AccentBrush"  Color="#4878B8"/> <!-- Calm reading blue -->

    <!-- Chat bubbles: warm off-white variations -->
    <SolidColorBrush x:Key="ClaudeBubbleBrush" Color="#EEE8DC"/> <!-- Warm cream -->
    <SolidColorBrush x:Key="OllamaBubbleBrush" Color="#EAE4D6"/> <!-- Slightly cooler cream -->
    <SolidColorBrush x:Key="UserBubbleBrush"   Color="#F4EFE6"/> <!-- Lightest warm white -->

</ResourceDictionary>
