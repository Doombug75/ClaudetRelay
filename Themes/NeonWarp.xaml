<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Neon Warp - Hintergründe -->
    <SolidColorBrush x:Key="BackgroundBrush" Color="#000020"/> <!-- Near Black/Deep Space -->
    <SolidColorBrush x:Key="SidebarBrush" Color="#050010"/>
    <SolidColorBrush x:Key="InputBrush" Color="#110033"/>
    <SolidColorBrush x:Key="SurfaceBrush" Color="#220044"/>

    <!-- Neon Warp - Text -->
    <SolidColorBrush x:Key="TextBrush" Color="#E0FFFF"/> <!-- Bright Aqua -->
    <SolidColorBrush x:Key="SubtextBrush" Color="#9999FF"/>

    <!-- Neon Warp - Akzente -->
    <SolidColorBrush x:Key="ClaudeBrush" Color="#FF00FF"/> <!-- Hot Magenta -->
    <SolidColorBrush x:Key="OllamaBrush" Color="#00FFFF"/> <!-- Cyan Neon -->
    <SolidColorBrush x:Key="UserBrush" Color="#FF69B4"/> <!-- Pink Pop -->
    <SolidColorBrush x:Key="AccentBrush" Color="#FFFF00"/> <!-- Electric Yellow -->

    <!-- Neon Warp - Bubble Hintergründe -->
    <SolidColorBrush x:Key="ClaudeBubbleBrush" Color="#050010"/>
    <SolidColorBrush x:Key="OllamaBubbleBrush" Color="#000020"/>
    <SolidColorBrush x:Key="UserBubbleBrush" Color="#000010"/>

</ResourceDictionary>



