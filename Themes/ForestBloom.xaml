<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Forest Bloom - Hintergründe -->
    <SolidColorBrush x:Key="BackgroundBrush" Color="#1F2A1F"/>
    <SolidColorBrush x:Key="SidebarBrush" Color="#172317"/>
    <SolidColorBrush x:Key="InputBrush" Color="#2B3A2B"/>
    <SolidColorBrush x:Key="SurfaceBrush" Color="#3B4D3B"/>

    <!-- Forest Bloom - Text -->
    <SolidColorBrush x:Key="TextBrush" Color="#E2E9D5"/>
    <SolidColorBrush x:Key="SubtextBrush" Color="#90A08B"/>

    <!-- Forest Bloom - Akzente -->
    <SolidColorBrush x:Key="ClaudeBrush" Color="#B08C5E"/> <!-- Warm Gold/Bronze -->
    <SolidColorBrush x:Key="OllamaBrush" Color="#8FA65B"/> <!-- Sage Green -->
    <SolidColorBrush x:Key="UserBrush" Color="#6AA873"/> <!-- Forest Green -->
    <SolidColorBrush x:Key="AccentBrush" Color="#D35400"/> <!-- Autumn Orange -->

    <!-- Forest Bloom - Bubble Hintergründe -->
    <SolidColorBrush x:Key="ClaudeBubbleBrush" Color="#1A221A"/>
    <SolidColorBrush x:Key="OllamaBubbleBrush" Color="#102010"/>
    <SolidColorBrush x:Key="UserBubbleBrush" Color="#121A12"/>

</ResourceDictionary>

