<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Meadow Bloom - Hintergründe (Helles, sprießendes Licht) -->
    <SolidColorBrush x:Key="BackgroundBrush" Color="#F5F9F0"/> <!-- Pale Cream / Misty White -->
    <SolidColorBrush x:Key="SidebarBrush" Color="#EAEBE5"/>
    <SolidColorBrush x:Key="InputBrush" Color="#E0E5E2"/>
    <SolidColorBrush x:Key="SurfaceBrush" Color="#D9E0D6"/>

    <!-- Meadow Bloom - Text (Weiches Schwarz, wie Schatten) -->
    <SolidColorBrush x:Key="TextBrush" Color="#4E5A4D"/>
    <SolidColorBrush x:Key="SubtextBrush" Color="#78887C"/>

    <!-- Meadow Bloom - Akzente (Frühlingshaft, blühend) -->
    <SolidColorBrush x:Key="ClaudeBrush" Color="#A3D99E"/> <!-- Gentle Spring Green -->
    <SolidColorBrush x:Key="OllamaBrush" Color="#6CB87A"/> <!-- Pastel Mint Green -->
    <SolidColorBrush x:Key="UserBrush" Color="#8DA6C4"/> <!-- Soft Sky Blue -->
    <SolidColorBrush x:Key="AccentBrush" Color="#FFD166"/> <!-- Soft Sunflower Yellow -->

    <!-- Meadow Bloom - Bubble Hintergründe -->
    <SolidColorBrush x:Key="ClaudeBubbleBrush" Color="#D5E2C4"/>
    <SolidColorBrush x:Key="OllamaBubbleBrush" Color="#C8DCD0"/>
    <SolidColorBrush x:Key="UserBubbleBrush" Color="#B0C0D2"/>

</ResourceDictionary>
