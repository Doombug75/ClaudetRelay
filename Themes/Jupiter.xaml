<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Jupiter - Hintergründe (Gegebändigte Mega-Stürme) -->
    <SolidColorBrush x:Key="BackgroundBrush" Color="#201510"/> <!-- Deep Mahogany Brown -->
    <SolidColorBrush x:Key="SidebarBrush" Color="#2A1F1A"/>
    <SolidColorBrush x:Key="InputBrush" Color="#3A2822"/>
    <SolidColorBrush x:Key="SurfaceBrush" Color="#4B3A33"/>

    <!-- Jupiter - Text (Monumental, tief, staubig) -->
    <SolidColorBrush x:Key="TextBrush" Color="#C0B09A"/>
    <SolidColorBrush x:Key="SubtextBrush" Color="#807060"/>

    <!-- Jupiter - Akzente (Atmosphären, Energie, Macht) -->
    <SolidColorBrush x:Key="ClaudeBrush" Color="#CC8833"/> <!-- Deep Saffron/Burnt Gold -->
    <SolidColorBrush x:Key="OllamaBrush" Color="#80AA70"/> <!-- Muted Teal/Weathering Green -->
    <SolidColorBrush x:Key="UserBrush" Color="#AA9966"/> <!-- Beige/Earth Tone -->
    <SolidColorBrush x:Key="AccentBrush" Color="#CC6633"/> <!-- Orange Swirl/Warning -->

    <!-- Jupiter - Bubble Hintergründe -->
    <SolidColorBrush x:Key="ClaudeBubbleBrush" Color="#2A1E18"/>
    <SolidColorBrush x:Key="OllamaBubbleBrush" Color="#1F251D"/>
    <SolidColorBrush x:Key="UserBubbleBrush" Color="#25221E"/>

</ResourceDictionary>
