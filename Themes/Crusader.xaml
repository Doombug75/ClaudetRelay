<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Crusader Industries — "Getting You There"                               -->
    <!-- Brand: clean blue/white, reliable civilian transport                    -->
    <!-- Cockpit displays: crisp blue/white interface — Mercury Star Runner      -->

    <!-- Backgrounds — clean civilian bulkhead, corporate blue -->
    <SolidColorBrush x:Key="BackgroundBrush" Color="#0A1220"/> <!-- Deep civilian navy      -->
    <SolidColorBrush x:Key="SidebarBrush"    Color="#070C18"/> <!-- Hull inner              -->
    <SolidColorBrush x:Key="InputBrush"      Color="#101E34"/> <!-- Panel recess            -->
    <SolidColorBrush x:Key="SurfaceBrush"    Color="#1A2E4C"/> <!-- Console surface         -->

    <!-- Text — clean, readable, civilian standard -->
    <SolidColorBrush x:Key="TextBrush"    Color="#DCE8F4"/> <!-- Cool clean white         -->
    <SolidColorBrush x:Key="SubtextBrush" Color="#4E70A0"/> <!-- Muted Crusader blue      -->

    <!-- Accents — Crusader blue, cyan, warm gold complement -->
    <SolidColorBrush x:Key="ClaudeBrush"  Color="#2080D0"/> <!-- Crusader signature blue  -->
    <SolidColorBrush x:Key="OllamaBrush"  Color="#38A8D0"/> <!-- Secondary cyan-blue      -->
    <SolidColorBrush x:Key="UserBrush"    Color="#78B8E8"/> <!-- Interface pale blue      -->
    <SolidColorBrush x:Key="AccentBrush"  Color="#E0A028"/> <!-- Gold accent — nav marker -->

    <!-- Bubble backgrounds — flight deck display tints -->
    <SolidColorBrush x:Key="ClaudeBubbleBrush" Color="#0C1C34"/> <!-- Deep nav blue        -->
    <SolidColorBrush x:Key="OllamaBubbleBrush" Color="#0A1A2C"/> <!-- Darker blue          -->
    <SolidColorBrush x:Key="UserBubbleBrush"   Color="#0C1C30"/> <!-- Comms blue           -->

</ResourceDictionary>
