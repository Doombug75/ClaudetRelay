<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Mars - Hintergründe (Dust, Eisenoxide, Verfall) -->
    <SolidColorBrush x:Key="BackgroundBrush" Color="#381E15"/> <!-- Deep Sienna Brown -->
    <SolidColorBrush x:Key="SidebarBrush" Color="#452B25"/>
    <SolidColorBrush x:Key="InputBrush" Color="#553830"/>
    <SolidColorBrush x:Key="SurfaceBrush" Color="#6A453A"/>

    <!-- Mars - Text (Verwittert, staubig) -->
    <SolidColorBrush x:Key="TextBrush" Color="#D0B090"/>
    <SolidColorBrush x:Key="SubtextBrush" Color="#908070"/>

    <!-- Mars - Akzente (Rost, Hitze, Wüste) -->
    <SolidColorBrush x:Key="ClaudeBrush" Color="#C26633"/> <!-- Deep Rust Brown -->
    <SolidColorBrush x:Key="OllamaBrush" Color="#AA8855"/> <!-- Desert Sand Green (minimaler Life-Glow) -->
    <SolidColorBrush x:Key="UserBrush" Color="#BC8A50"/> <!-- Aged Copper/Sand -->
    <SolidColorBrush x:Key="AccentBrush" Color="#BF4000"/> <!-- Danger Orange/Red -->

    <!-- Mars - Bubble Hintergründe -->
    <SolidColorBrush x:Key="ClaudeBubbleBrush" Color="#2B2118"/>
    <SolidColorBrush x:Key="OllamaBubbleBrush" Color="#1E251A"/>
    <SolidColorBrush x:Key="UserBubbleBrush" Color="#28231E"/>

</ResourceDictionary>
