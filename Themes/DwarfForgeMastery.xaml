<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Dwarf Forge Mastery - Hintergründe (Schweres Gestein, Schmiede) -->
    <SolidColorBrush x:Key="BackgroundBrush" Color="#120C0A"/> <!-- Coal Black / Deep Ore -->
    <SolidColorBrush x:Key="SidebarBrush" Color="#1D1510"/>
    <SolidColorBrush x:Key="InputBrush" Color="#2A201D"/>
    <SolidColorBrush x:Key="SurfaceBrush" Color="#382C22"/>

    <!-- Dwarf Forge Mastery - Text (Geätztes Metall, Stein) -->
    <SolidColorBrush x:Key="TextBrush" Color="#D4CCC9"/>
    <SolidColorBrush x:Key="SubtextBrush" Color="#9F958E"/>

    <!-- Dwarf Forge Mastery - Akzente (Hitze, Metall, Macht) -->
    <SolidColorBrush x:Key="ClaudeBrush" Color="#CC6633"/> <!-- Copper/Burnt Brass (Das Meisterwerk) -->
    <SolidColorBrush x:Key="OllamaBrush" Color="#4D9E8B"/> <!-- Forged Steel Green (Functional Tech) -->
    <SolidColorBrush x:Key="UserBrush" Color="#CC9966"/> <!-- Aged Bronze/Copper (Der Handwerker) -->
    <SolidColorBrush x:Key="AccentBrush" Color="#FF4400"/> <!-- MAGMA CORE RED (Die ultimative Gefahr) -->

    <!-- Dwarf Forge Mastery - Bubble Hintergründe -->
    <SolidColorBrush x:Key="ClaudeBubbleBrush" Color="#18120C"/>
    <SolidColorBrush x:Key="OllamaBubbleBrush" Color="#121810"/>
    <SolidColorBrush x:Key="UserBubbleBrush" Color="#1A1612"/>

</ResourceDictionary>

