<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Captain Future — "Comet, Full Speed Ahead!"                               -->
    <!-- Brand: retro-anime 70s sci-fi — deep space navy, Comet-rocket orange      -->
    <!-- Aesthetic: starfields, alien worlds in neon, Simon Wright's blue glow     -->

    <!-- Backgrounds — deep space, void between worlds -->
    <SolidColorBrush x:Key="BackgroundBrush" Color="#060A14"/> <!-- Deep space navy-black    -->
    <SolidColorBrush x:Key="SidebarBrush"    Color="#040810"/> <!-- Star-void deep           -->
    <SolidColorBrush x:Key="InputBrush"      Color="#0A1020"/> <!-- Panel recess             -->
    <SolidColorBrush x:Key="SurfaceBrush"    Color="#121828"/> <!-- Comet cockpit surface    -->

    <!-- Text — starfield white-blue, space log -->
    <SolidColorBrush x:Key="TextBrush"    Color="#D8EEF8"/> <!-- Starfield cool white     -->
    <SolidColorBrush x:Key="SubtextBrush" Color="#4870A8"/> <!-- Muted space blue         -->

    <!-- Accents — Comet-rocket orange, mission blue, alien-world cyan, comet gold -->
    <SolidColorBrush x:Key="ClaudeBrush"  Color="#E87820"/> <!-- Cap's suit orange        -->
    <SolidColorBrush x:Key="OllamaBrush"  Color="#3888D8"/> <!-- Space-mission blue       -->
    <SolidColorBrush x:Key="UserBrush"    Color="#70D8F0"/> <!-- Alien world cyan         -->
    <SolidColorBrush x:Key="AccentBrush"  Color="#F0D040"/> <!-- Comet trail gold         -->

    <!-- Bubble backgrounds — cockpit display tints -->
    <SolidColorBrush x:Key="ClaudeBubbleBrush" Color="#180C04"/> <!-- Dark rocket-orange   -->
    <SolidColorBrush x:Key="OllamaBubbleBrush" Color="#061018"/> <!-- Deep space blue      -->
    <SolidColorBrush x:Key="UserBubbleBrush"   Color="#061418"/> <!-- Alien cyan dark      -->

</ResourceDictionary>
