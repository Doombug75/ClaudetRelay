<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- InuYasha — "Sit! / Osuwari!"                                              -->
    <!-- Brand: fire-rat robe red, silver dog-demon, feudal Japan night            -->
    <!-- Aesthetic: Sengoku era forest, Tessaiga Wind Scar, Sesshomaru purple      -->

    <!-- Backgrounds — feudal Japan night, ancient forest dark -->
    <SolidColorBrush x:Key="BackgroundBrush" Color="#0A0810"/> <!-- Feudal night, violet-dark-->
    <SolidColorBrush x:Key="SidebarBrush"    Color="#070610"/> <!-- Deeper forest shadow     -->
    <SolidColorBrush x:Key="InputBrush"      Color="#120E1A"/> <!-- Panel recess             -->
    <SolidColorBrush x:Key="SurfaceBrush"    Color="#1A1424"/> <!-- Ancient surface          -->

    <!-- Text — aged scroll parchment, feudal era -->
    <SolidColorBrush x:Key="TextBrush"    Color="#D8D0B8"/> <!-- Aged scroll parchment    -->
    <SolidColorBrush x:Key="SubtextBrush" Color="#706080"/> <!-- Muted feudal purple      -->

    <!-- Accents — fire-rat robe red, Sesshomaru violet, Kagome blue -->
    <SolidColorBrush x:Key="ClaudeBrush"  Color="#C82020"/> <!-- Fire-rat robe red        -->
    <SolidColorBrush x:Key="OllamaBrush"  Color="#8058C8"/> <!-- Sesshomaru violet        -->
    <SolidColorBrush x:Key="UserBrush"    Color="#3868C8"/> <!-- Kagome's uniform blue    -->
    <SolidColorBrush x:Key="AccentBrush"  Color="#E03828"/> <!-- Tessaiga Wind Scar glow  -->

    <!-- Bubble backgrounds — demon aura tints -->
    <SolidColorBrush x:Key="ClaudeBubbleBrush" Color="#180808"/> <!-- Dark fire-rat red    -->
    <SolidColorBrush x:Key="OllamaBubbleBrush" Color="#100C1C"/> <!-- Deep Sesshomaru      -->
    <SolidColorBrush x:Key="UserBubbleBrush"   Color="#0A0C18"/> <!-- Kagome blue dark     -->

</ResourceDictionary>
