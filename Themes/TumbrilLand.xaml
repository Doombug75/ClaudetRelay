<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Tumbril Land Systems — "Engineered for Combat"                            -->
    <!-- Brand: military olive-green, khaki, heavy armor — Nova, Cyclone, Ranger  -->
    <!-- Cockpit displays: tactical green on dark — Nova tank fire control         -->

    <!-- Backgrounds — military dark green-black, field ops -->
    <SolidColorBrush x:Key="BackgroundBrush" Color="#080C08"/> <!-- Military dark green-black-->
    <SolidColorBrush x:Key="SidebarBrush"    Color="#060806"/> <!-- Deeper field ops         -->
    <SolidColorBrush x:Key="InputBrush"      Color="#0E1208"/> <!-- Panel recess             -->
    <SolidColorBrush x:Key="SurfaceBrush"    Color="#161C10"/> <!-- Armoured console surface -->

    <!-- Text — field manual khaki, tactical readout -->
    <SolidColorBrush x:Key="TextBrush"    Color="#C8C8A8"/> <!-- Field manual khaki        -->
    <SolidColorBrush x:Key="SubtextBrush" Color="#507050"/> <!-- Muted tactical green      -->

    <!-- Accents — military olive, Nova tan hull, tactical green -->
    <SolidColorBrush x:Key="ClaudeBrush"  Color="#709030"/> <!-- Tumbril military olive    -->
    <SolidColorBrush x:Key="OllamaBrush"  Color="#907828"/> <!-- Nova hull tan/rust        -->
    <SolidColorBrush x:Key="UserBrush"    Color="#9A9858"/> <!-- Khaki field interface     -->
    <SolidColorBrush x:Key="AccentBrush"  Color="#90A838"/> <!-- Tactical fire-control green-->

    <!-- Bubble backgrounds — fire control display tints -->
    <SolidColorBrush x:Key="ClaudeBubbleBrush" Color="#0C1008"/> <!-- Dark olive tint       -->
    <SolidColorBrush x:Key="OllamaBubbleBrush" Color="#100E06"/> <!-- Dark khaki            -->
    <SolidColorBrush x:Key="UserBubbleBrush"   Color="#0E1008"/> <!-- Military green dark   -->

</ResourceDictionary>
