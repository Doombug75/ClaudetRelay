<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- High Contrast Dark -->
    <!-- Pure black background with maximum contrast — designed for visual accessibility (WCAG AAA) -->
    <SolidColorBrush x:Key="BackgroundBrush" Color="#000000"/> <!-- Pure black -->
    <SolidColorBrush x:Key="SidebarBrush"   Color="#080808"/> <!-- Near-pure black -->
    <SolidColorBrush x:Key="InputBrush"     Color="#1C1C1C"/> <!-- Very dark grey — clearly distinct -->
    <SolidColorBrush x:Key="SurfaceBrush"   Color="#2C2C2C"/> <!-- Slightly lighter dark -->

    <!-- Text: pure white on black — maximum contrast -->
    <SolidColorBrush x:Key="TextBrush"    Color="#FFFFFF"/> <!-- Pure white -->
    <SolidColorBrush x:Key="SubtextBrush" Color="#FFFF00"/> <!-- Bright yellow — classic high-contrast secondary -->

    <!-- Accents: vivid, distinct colours — unambiguous even with colour vision deficiencies -->
    <SolidColorBrush x:Key="ClaudeBrush"  Color="#00FF88"/> <!-- Vivid cyan-green -->
    <SolidColorBrush x:Key="OllamaBrush"  Color="#00CFFF"/> <!-- Vivid cyan -->
    <SolidColorBrush x:Key="UserBrush"    Color="#FFAA00"/> <!-- Vivid amber -->
    <SolidColorBrush x:Key="AccentBrush"  Color="#FFFF00"/> <!-- Bright yellow -->

    <!-- Chat bubbles: near-black with subtle colour tint for orientation -->
    <SolidColorBrush x:Key="ClaudeBubbleBrush" Color="#0A0F08"/> <!-- Near-black, green hint -->
    <SolidColorBrush x:Key="OllamaBubbleBrush" Color="#080C0F"/> <!-- Near-black, blue hint -->
    <SolidColorBrush x:Key="UserBubbleBrush"   Color="#0F0A00"/> <!-- Near-black, amber hint -->

</ResourceDictionary>
