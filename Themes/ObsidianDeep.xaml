<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Obsidian Deep - Hintergründe (Volkanisches Glas, Absorption) -->
    <SolidColorBrush x:Key="BackgroundBrush" Color="#050308"/> <!-- True Abyss Black -->
    <SolidColorBrush x:Key="SidebarBrush" Color="#08040B"/>
    <SolidColorBrush x:Key="InputBrush" Color="#0B0610"/>
    <SolidColorBrush x:Key="SurfaceBrush" Color="#120F16"/>

    <!-- Obsidian Deep - Text (Glühend, reflektierend) -->
    <SolidColorBrush x:Key="TextBrush" Color="#B5C0E0"/> <!-- Pale Silver/Mist Blue -->
    <SolidColorBrush x:Key="SubtextBrush" Color="#708090"/>

    <!-- Obsidian Deep - Akzente (Kristall, magische Quelle) -->
    <SolidColorBrush x:Key="ClaudeBrush" Color="#8C40FF"/> <!-- Intense Royal Violet/Mana -->
    <SolidColorBrush x:Key="OllamaBrush" Color="#20FFC2"/> <!-- Cyan/Emerald Glow (Energiewelle) -->
    <SolidColorBrush x:Key="UserBrush" Color="#B0A0FF"/> <!-- Soft Purple Glow -->
    <SolidColorBrush x:Key="AccentBrush" Color="#FF4444"/> <!-- Warning Crimson/Deep Scarlet -->

    <!-- Obsidian Deep - Bubble Hintergründe -->
    <SolidColorBrush x:Key="ClaudeBubbleBrush" Color="#080308"/>
    <SolidColorBrush x:Key="OllamaBubbleBrush" Color="#040A06"/>
    <SolidColorBrush x:Key="UserBubbleBrush" Color="#070206"/>

</ResourceDictionary>
