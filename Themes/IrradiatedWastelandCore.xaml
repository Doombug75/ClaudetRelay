<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Irradiated Wasteland Core - Hintergründe (Staub, Verfall, Rost) -->
    <SolidColorBrush x:Key="BackgroundBrush" Color="#1D1812"/> <!-- Dark Grime Brown/Gray -->
    <SolidColorBrush x:Key="SidebarBrush" Color="#25201C"/>
    <SolidColorBrush x:Key="InputBrush" Color="#302824"/>
    <SolidColorBrush x:Key="SurfaceBrush" Color="#403833"/>

    <!-- Irradiated Wasteland Core - Text (Verblasst, müde) -->
    <SolidColorBrush x:Key="TextBrush" Color="#C5C0B0"/>
    <SolidColorBrush x:Key="SubtextBrush" Color="#807565"/>

    <!-- Irradiated Wasteland Core - Akzente (Gefahr, Radiation) -->
    <SolidColorBrush x:Key="ClaudeBrush" Color="#D2B53D"/> <!-- Mustard Yellow (Artefakt-Glow) -->
    <SolidColorBrush x:Key="OllamaBrush" Color="#66FF66"/> <!-- Sickly Radioactive Green (Radiation Alert) -->
    <SolidColorBrush x:Key="UserBrush" Color="#CC99FF"/> <!-- Purple/Electric Discharge (Powered Device) -->
    <SolidColorBrush x:Key="AccentBrush" Color="#D40000"/> <!-- Critical Red (Danger Sign) -->

    <!-- Irradiated Wasteland Core - Bubble Hintergründe -->
    <SolidColorBrush x:Key="ClaudeBubbleBrush" Color="#1A1610"/>
    <SolidColorBrush x:Key="OllamaBubbleBrush" Color="#0B120B"/>
    <SolidColorBrush x:Key="UserBubbleBrush" Color="#150B10"/>

</ResourceDictionary>





