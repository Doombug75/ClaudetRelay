<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Irradiated Wasteland Core — "Warning: Radiation Level Critical"           -->
    <!-- Brand: ash grey, sickly radioactive green, rust red — decay and rads      -->
    <!-- Aesthetic: Geiger counter clicks, glowing barrels, dead zone atmosphere   -->

    <!-- Backgrounds — ash and grime, post-nuclear decay -->
    <SolidColorBrush x:Key="BackgroundBrush" Color="#1D1812"/> <!-- Dark grime ash brown     -->
    <SolidColorBrush x:Key="SidebarBrush"    Color="#25201C"/> <!-- Deeper ashen wall        -->
    <SolidColorBrush x:Key="InputBrush"      Color="#302824"/> <!-- Panel recess             -->
    <SolidColorBrush x:Key="SurfaceBrush"    Color="#403833"/> <!-- Corroded console surface -->

    <!-- Text — faded, tired, survival standard -->
    <SolidColorBrush x:Key="TextBrush"    Color="#C5C0B0"/> <!-- Bleached ash white        -->
    <SolidColorBrush x:Key="SubtextBrush" Color="#807565"/> <!-- Muted dust                -->

    <!-- Accents — radiation alert, artefact glow, danger signs -->
    <SolidColorBrush x:Key="ClaudeBrush"  Color="#D2B53D"/> <!-- Mustard artefact-glow     -->
    <SolidColorBrush x:Key="OllamaBrush"  Color="#50C840"/> <!-- Sickly radioactive green  -->
    <SolidColorBrush x:Key="UserBrush"    Color="#A878D8"/> <!-- Electric discharge purple -->
    <SolidColorBrush x:Key="AccentBrush"  Color="#D42020"/> <!-- Critical red — DANGER     -->

    <!-- Bubble backgrounds — contaminated display tints -->
    <SolidColorBrush x:Key="ClaudeBubbleBrush" Color="#1A1610"/> <!-- Dark mustard tint     -->
    <SolidColorBrush x:Key="OllamaBubbleBrush" Color="#0C1408"/> <!-- Dark rad-green        -->
    <SolidColorBrush x:Key="UserBubbleBrush"   Color="#160C1C"/> <!-- Dark purple discharge -->

</ResourceDictionary>
