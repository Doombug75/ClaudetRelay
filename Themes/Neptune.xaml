<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Neptune - Hintergründe (Der Tiefsee-Ozean) -->
    <SolidColorBrush x:Key="BackgroundBrush" Color="#050310"/> <!-- Ultra Deep Indigo/Black -->
    <SolidColorBrush x:Key="SidebarBrush" Color="#0A0713"/>
    <SolidColorBrush x:Key="InputBrush" Color="#101520"/>
    <SolidColorBrush x:Key="SurfaceBrush" Color="#1A202B"/>

    <!-- Neptune - Text (Leuchtendes, aber gedämpftes Licht) -->
    <SolidColorBrush x:Key="TextBrush" Color="#B0C0FF"/>
    <SolidColorBrush x:Key="SubtextBrush" Color="#8090C0"/>

    <!-- Neptune - Akzente (Ultramarin, Tiefsee-Glühen) -->
    <SolidColorBrush x:Key="ClaudeBrush" Color="#4A78C0"/> <!-- Deep Royal Blue -->
    <SolidColorBrush x:Key="OllamaBrush" Color="#3399FF"/> <!-- Electric Medium Blue (Wasser) -->
    <SolidColorBrush x:Key="UserBrush" Color="#6A90FF"/> <!-- Lighter Cyan Blue -->
    <SolidColorBrush x:Key="AccentBrush" Color="#9966CC"/> <!-- Deep Violet Pop (Mystery) -->

    <!-- Neptune - Bubble Hintergründe -->
    <SolidColorBrush x:Key="ClaudeBubbleBrush" Color="#03070D"/>
    <SolidColorBrush x:Key="OllamaBubbleBrush" Color="#01060A"/>
    <SolidColorBrush x:Key="UserBubbleBrush" Color="#050910"/>

</ResourceDictionary>
