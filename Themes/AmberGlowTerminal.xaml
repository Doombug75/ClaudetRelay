<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Amberglow Terminal - Hintergründe (Warm, vergilbtes Display) -->
    <SolidColorBrush x:Key="BackgroundBrush" Color="#0A0502"/> <!-- Very Deep Brown/Near Black -->
    <SolidColorBrush x:Key="SidebarBrush" Color="#141010"/>
    <SolidColorBrush x:Key="InputBrush" Color="#181218"/>
    <SolidColorBrush x:Key="SurfaceBrush" Color="#252020"/>

    <!-- Amberglow Terminal - Text (Der warme, flackernde Glow) -->
    <SolidColorBrush x:Key="TextBrush" Color="#FFC366"/> <!-- Amber Glow -->
    <SolidColorBrush x:Key="SubtextBrush" Color="#B5884A"/>

    <!-- Amberglow Terminal - Akzente (Kerzenschein, Warnlicht) -->
    <SolidColorBrush x:Key="ClaudeBrush" Color="#FF9900"/> <!-- Deep Safety Orange -->
    <SolidColorBrush x:Key="OllamaBrush" Color="#CCAA66"/> <!-- Dusty Gold/Mustard -->
    <SolidColorBrush x:Key="UserBrush" Color="#FFB300"/> <!-- Warning Orange -->
    <SolidColorBrush x:Key="AccentBrush" Color="#FFD700"/> <!-- Classic Gold Flash -->

    <!-- Amberglow Terminal - Bubble Hintergründe -->
    <SolidColorBrush x:Key="ClaudeBubbleBrush" Color="#150A08"/>
    <SolidColorBrush x:Key="OllamaBubbleBrush" Color="#0B0804"/>
    <SolidColorBrush x:Key="UserBubbleBrush" Color="#12070C"/>

</ResourceDictionary>




