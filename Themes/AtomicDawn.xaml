<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Atomic Dawn - Hintergründe -->
    <SolidColorBrush x:Key="BackgroundBrush" Color="#14192B"/> <!-- Deep Navy Blue -->
    <SolidColorBrush x:Key="SidebarBrush" Color="#101622"/>
    <SolidColorBrush x:Key="InputBrush" Color="#1E253A"/>
    <SolidColorBrush x:Key="SurfaceBrush" Color="#283450"/>

    <!-- Atomic Dawn - Text -->
    <SolidColorBrush x:Key="TextBrush" Color="#D9E6F2"/>
    <SolidColorBrush x:Key="SubtextBrush" Color="#879EA8"/>

    <!-- Atomic Dawn - Akzente -->
    <SolidColorBrush x:Key="ClaudeBrush" Color="#FF6347"/> <!-- Classic Orange/Coral -->
    <SolidColorBrush x:Key="OllamaBrush" Color="#40E0D0"/> <!-- Turquoise Teal -->
    <SolidColorBrush x:Key="UserBrush" Color="#7B68EE"/> <!-- Royal Purple -->
    <SolidColorBrush x:Key="AccentBrush" Color="#FFD700"/> <!-- Gold Yellow -->

    <!-- Atomic Dawn - Bubble Hintergründe -->
    <SolidColorBrush x:Key="ClaudeBubbleBrush" Color="#1F2238"/>
    <SolidColorBrush x:Key="OllamaBubbleBrush" Color="#101A2A"/>
    <SolidColorBrush x:Key="UserBubbleBrush" Color="#161B30"/>

</ResourceDictionary>



