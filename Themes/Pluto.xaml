<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Pluto - Hintergründe (Frozen, leer, starr) -->
    <SolidColorBrush x:Key="BackgroundBrush" Color="#07080C"/> <!-- Cosmic Cold Black -->
    <SolidColorBrush x:Key="SidebarBrush" Color="#101218"/>
    <SolidColorBrush x:Key="InputBrush" Color="#151920"/>
    <SolidColorBrush x:Key="SurfaceBrush" Color="#202430"/>

    <!-- Pluto - Text (Sehr blasses, kühles Licht) -->
    <SolidColorBrush x:Key="TextBrush" Color="#DDE0FF"/>
    <SolidColorBrush x:Key="SubtextBrush" Color="#8090B0"/>

    <!-- Pluto - Akzente (Extreme Kälte, Eisglanz, winzige Energiequelle) -->
    <SolidColorBrush x:Key="ClaudeBrush" Color="#80A0FF"/> <!-- Faint, pale blue glow -->
    <SolidColorBrush x:Key="OllamaBrush" Color="#A0C0D0"/> <!-- Frosty Pale Aqua -->
    <SolidColorBrush x:Key="UserBrush" Color="#B0C0FF"/> <!-- Ghostly Lavender -->
    <SolidColorBrush x:Key="AccentBrush" Color="#8080A0"/> <!-- Grey-Purple (Distant glow) -->

    <!-- Pluto - Bubble Hintergründe -->
    <SolidColorBrush x:Key="ClaudeBubbleBrush" Color="#05080C"/>
    <SolidColorBrush x:Key="OllamaBubbleBrush" Color="#030609"/>
    <SolidColorBrush x:Key="UserBubbleBrush" Color="#101215"/>

</ResourceDictionary>
