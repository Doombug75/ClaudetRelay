<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- The Minutemen — "We Answer the Call"                                      -->
    <!-- Brand: colonial blue coat, musket brass, tricorn hat gold                 -->
    <!-- Aesthetic: American frontier revival, Sanctuary Hills, "protect the people"-->

    <!-- Backgrounds — colonial midnight, Concord night patrol -->
    <SolidColorBrush x:Key="BackgroundBrush" Color="#08101C"/> <!-- Colonial midnight navy   -->
    <SolidColorBrush x:Key="SidebarBrush"    Color="#060C16"/> <!-- Deeper night             -->
    <SolidColorBrush x:Key="InputBrush"      Color="#0E1A2C"/> <!-- Panel recess             -->
    <SolidColorBrush x:Key="SurfaceBrush"    Color="#162440"/> <!-- Console surface          -->

    <!-- Text — clean white-blue, broadcast frequency -->
    <SolidColorBrush x:Key="TextBrush"    Color="#D4DEF0"/> <!-- Cool clean white-blue    -->
    <SolidColorBrush x:Key="SubtextBrush" Color="#485A90"/> <!-- Muted colonial blue      -->

    <!-- Accents — Minutemen coat blue, musket brass, warm gold -->
    <SolidColorBrush x:Key="ClaudeBrush"  Color="#3870B8"/> <!-- Minutemen coat blue      -->
    <SolidColorBrush x:Key="OllamaBrush"  Color="#C89020"/> <!-- Musket brass — "the call"-->
    <SolidColorBrush x:Key="UserBrush"    Color="#7898CC"/> <!-- Pale colonial interface  -->
    <SolidColorBrush x:Key="AccentBrush"  Color="#D4A828"/> <!-- Bright gold — General    -->

    <!-- Bubble backgrounds — radio broadcast tints -->
    <SolidColorBrush x:Key="ClaudeBubbleBrush" Color="#0A1420"/> <!-- Deep colonial blue   -->
    <SolidColorBrush x:Key="OllamaBubbleBrush" Color="#121008"/> <!-- Dark brass           -->
    <SolidColorBrush x:Key="UserBubbleBrush"   Color="#0A1220"/> <!-- Night patrol blue    -->

</ResourceDictionary>
