<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Savannah At Dusk - Hintergründe (Sepia, goldener Staub) -->
    <SolidColorBrush x:Key="BackgroundBrush" Color="#E9DBCF"/> <!-- Warm Cream/Dusty Beige -->
    <SolidColorBrush x:Key="SidebarBrush" Color="#DBCB9A"/>
    <SolidColorBrush x:Key="InputBrush" Color="#D1C9B5"/>
    <SolidColorBrush x:Key="SurfaceBrush" Color="#C0B89A"/>

    <!-- Savannah At Dusk - Text (Vergilbte Pergamenttöne) -->
    <SolidColorBrush x:Key="TextBrush" Color="#4E4A3F"/>
    <SolidColorBrush x:Key="SubtextBrush" Color="#6B756E"/>

    <!-- Savannah At Dusk - Akzente (Sonnenuntergang, Ocker, Staub) -->
    <SolidColorBrush x:Key="ClaudeBrush" Color="#CC9933"/> <!-- Aged Bronze/Ochre -->
    <SolidColorBrush x:Key="OllamaBrush" Color="#9EAE78"/> <!-- Faded Sage Green -->
    <SolidColorBrush x:Key="UserBrush" Color="#8D7A50"/> <!-- Dusty Taupe Brown -->
    <SolidColorBrush x:Key="AccentBrush" Color="#D27B35"/> <!-- Deep Rust Orange -->

    <!-- Savannah At Dusk - Bubble Hintergründe -->
    <SolidColorBrush x:Key="ClaudeBubbleBrush" Color="#E2D5C6"/>
    <SolidColorBrush x:Key="OllamaBubbleBrush" Color="#D0CEBF"/>
    <SolidColorBrush x:Key="UserBubbleBrush" Color="#CBAA99"/>

</ResourceDictionary>
