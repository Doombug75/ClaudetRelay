<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Catppuccin Frappé - Hintergründe -->
    <SolidColorBrush x:Key="BackgroundBrush" Color="#303446"/>
    <SolidColorBrush x:Key="SidebarBrush" Color="#292C3C"/>
    <SolidColorBrush x:Key="InputBrush" Color="#414559"/>
    <SolidColorBrush x:Key="SurfaceBrush" Color="#51576D"/>

    <!-- Catppuccin Frappé - Text -->
    <SolidColorBrush x:Key="TextBrush" Color="#C6D0F5"/>
    <SolidColorBrush x:Key="SubtextBrush" Color="#737994"/>

    <!-- Catppuccin Frappé - Akzente -->
    <SolidColorBrush x:Key="ClaudeBrush" Color="#CA9EE6"/>
    <SolidColorBrush x:Key="OllamaBrush" Color="#A6D189"/>
    <SolidColorBrush x:Key="UserBrush" Color="#8CAAEE"/>
    <SolidColorBrush x:Key="AccentBrush" Color="#E78284"/>

    <!-- Catppuccin Frappé - Bubble Hintergründe -->
    <SolidColorBrush x:Key="ClaudeBubbleBrush" Color="#3A3050"/>
    <SolidColorBrush x:Key="OllamaBubbleBrush" Color="#2A3828"/>
    <SolidColorBrush x:Key="UserBubbleBrush" Color="#2A3045"/>

</ResourceDictionary>