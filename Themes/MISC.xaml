<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- MISC — Musashi Industrial & Starflight Concern                          -->
    <!-- Brand: industrial orange/yellow, steel grey — functional, reliable     -->
    <!-- Cockpit displays: orange accent on dark industrial — Freelancer, Hull  -->

    <!-- Backgrounds — industrial manufacturing dark, steel grey -->
    <SolidColorBrush x:Key="BackgroundBrush" Color="#0C0E12"/> <!-- Dark industrial steel  -->
    <SolidColorBrush x:Key="SidebarBrush"    Color="#08090D"/> <!-- Factory floor dark     -->
    <SolidColorBrush x:Key="InputBrush"      Color="#141820"/> <!-- Panel recess           -->
    <SolidColorBrush x:Key="SurfaceBrush"    Color="#202630"/> <!-- Console surface        -->

    <!-- Text — functional, no-nonsense -->
    <SolidColorBrush x:Key="TextBrush"    Color="#D8D0C0"/> <!-- Warm industrial white   -->
    <SolidColorBrush x:Key="SubtextBrush" Color="#687078"/> <!-- Muted steel grey        -->

    <!-- Accents — MISC signature orange, industrial amber, steel blue -->
    <SolidColorBrush x:Key="ClaudeBrush"  Color="#E07818"/> <!-- MISC signature orange   -->
    <SolidColorBrush x:Key="OllamaBrush"  Color="#C06010"/> <!-- Darker industrial orange -->
    <SolidColorBrush x:Key="UserBrush"    Color="#6898B8"/> <!-- Steel nav blue          -->
    <SolidColorBrush x:Key="AccentBrush"  Color="#F0A030"/> <!-- Bright amber warning    -->

    <!-- Bubble backgrounds — industrial display tints -->
    <SolidColorBrush x:Key="ClaudeBubbleBrush" Color="#1A1008"/> <!-- Dark orange tint     -->
    <SolidColorBrush x:Key="OllamaBubbleBrush" Color="#160E06"/> <!-- Deeper orange        -->
    <SolidColorBrush x:Key="UserBubbleBrush"   Color="#101520"/> <!-- Steel blue dark      -->

</ResourceDictionary>
