<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Emergency Breach Terminal - Hintergründe (Hochspannung, Gefahr) -->
    <SolidColorBrush x:Key="BackgroundBrush" Color="#0A0000"/> <!-- Deep Space Crimson -->
    <SolidColorBrush x:Key="SidebarBrush" Color="#150505"/>
    <SolidColorBrush x:Key="InputBrush" Color="#1D0808"/>
    <SolidColorBrush x:Key="SurfaceBrush" Color="#280C10"/>

    <!-- Emergency Breach Terminal - Text (Das flackernde Warnrot) -->
    <SolidColorBrush x:Key="TextBrush" Color="#FF6666"/> <!-- Alert Red Glow -->
    <SolidColorBrush x:Key="SubtextBrush" Color="#993333"/>

    <!-- Emergency Breach Terminal - Akzente (Kritische Zustandsanzeige) -->
    <SolidColorBrush x:Key="ClaudeBrush" Color="#FF3333"/> <!-- Primary Alert Red -->
    <SolidColorBrush x:Key="OllamaBrush" Color="#FFAA00"/> <!-- Warning Amber/Orange -->
    <SolidColorBrush x:Key="UserBrush" Color="#FF66FF"/> <!-- Pulsating Purple (Anomalie) -->
    <SolidColorBrush x:Key="AccentBrush" Color="#CC0000"/> <!-- Critical Stop Red -->

    <!-- Emergency Breach Terminal - Bubble Hintergründe -->
    <SolidColorBrush x:Key="ClaudeBubbleBrush" Color="#110303"/>
    <SolidColorBrush x:Key="OllamaBubbleBrush" Color="#0D0101"/>
    <SolidColorBrush x:Key="UserBubbleBrush" Color="#0E0204"/>

</ResourceDictionary>





