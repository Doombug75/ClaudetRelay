<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Retro Terminal Glow - Hintergründe (Die schwarze CRT-Pixelwand) -->
    <SolidColorBrush x:Key="BackgroundBrush" Color="#020602"/> <!-- Near Black (Vacuum) -->
    <SolidColorBrush x:Key="SidebarBrush" Color="#050A05"/>
    <SolidColorBrush x:Key="InputBrush" Color="#091409"/>
    <SolidColorBrush x:Key="SurfaceBrush" Color="#151D15"/>

    <!-- Retro Terminal Glow - Text (Der Phosphor-Glow) -->
    <SolidColorBrush x:Key="TextBrush" Color="#00FF00"/> <!-- Vivid Phosphor Green -->
    <SolidColorBrush x:Key="SubtextBrush" Color="#33AA33"/> <!-- Dimmer System Green -->

    <!-- Retro Terminal Glow - Akzente (Funktional, Signalisiert) -->
    <SolidColorBrush x:Key="ClaudeBrush" Color="#00CC00"/> <!-- Bright Operational Green -->
    <SolidColorBrush x:Key="OllamaBrush" Color="#FFFF66"/> <!-- Amber Warning/Status Yellow -->
    <SolidColorBrush x:Key="UserBrush" Color="#66FF66"/> <!-- User Input Glow -->
    <SolidColorBrush x:Key="AccentBrush" Color="#AAFFAA"/> <!-- Confirmation/Success Pale Green -->

    <!-- Retro Terminal Glow - Bubble Hintergründe -->
    <SolidColorBrush x:Key="ClaudeBubbleBrush" Color="#010501"/>
    <SolidColorBrush x:Key="OllamaBubbleBrush" Color="#000800"/>
    <SolidColorBrush x:Key="UserBubbleBrush" Color="#020402"/>

</ResourceDictionary>




