<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Mercury - Hintergründe (Polierter, metallischer Look) -->
    <SolidColorBrush x:Key="BackgroundBrush" Color="#141417"/> <!-- Deep Graphite Black -->
    <SolidColorBrush x:Key="SidebarBrush" Color="#202328"/>
    <SolidColorBrush x:Key="InputBrush" Color="#283038"/>
    <SolidColorBrush x:Key="SurfaceBrush" Color="#3A4550"/>

    <!-- Mercury - Text (Strahlender, kühler Glanz) -->
    <SolidColorBrush x:Key="TextBrush" Color="#C0D0E0"/>
    <SolidColorBrush x:Key="SubtextBrush" Color="#8090A0"/>

    <!-- Mercury - Akzente (Extreme Hitze, Metall, schnelle Impulse) -->
    <SolidColorBrush x:Key="ClaudeBrush" Color="#FFB300"/> <!-- Bright Amber/Reflected Heat -->
    <SolidColorBrush x:Key="OllamaBrush" Color="#A0E0FF"/> <!-- Electrical Cyan (Signal) -->
    <SolidColorBrush x:Key="UserBrush" Color="#C0D0E0"/> <!-- Cool Chrome Silver -->
    <SolidColorBrush x:Key="AccentBrush" Color="#CC6600"/> <!-- Molten Orange/Rust -->

    <!-- Mercury - Bubble Hintergründe -->
    <SolidColorBrush x:Key="ClaudeBubbleBrush" Color="#1A1E25"/>
    <SolidColorBrush x:Key="OllamaBubbleBrush" Color="#101A25"/>
    <SolidColorBrush x:Key="UserBubbleBrush" Color="#151A22"/>

</ResourceDictionary>
