<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ClearDay -->
    <!-- Fresh, airy light blue-white — like a bright morning with clear sky -->
    <SolidColorBrush x:Key="BackgroundBrush" Color="#F2F6FB"/> <!-- Very light cool blue-white -->
    <SolidColorBrush x:Key="SidebarBrush"   Color="#E2EAF5"/> <!-- Soft blue-grey -->
    <SolidColorBrush x:Key="InputBrush"     Color="#D0DCF0"/> <!-- Slightly more saturated -->
    <SolidColorBrush x:Key="SurfaceBrush"   Color="#BCCCE8"/> <!-- Medium blue-grey -->

    <!-- Text: very dark blue-black — clear and sharp -->
    <SolidColorBrush x:Key="TextBrush"    Color="#101828"/> <!-- Near-black with cool blue tint -->
    <SolidColorBrush x:Key="SubtextBrush" Color="#607090"/> <!-- Muted slate blue -->

    <!-- Accents: clear blues — calm and professional -->
    <SolidColorBrush x:Key="ClaudeBrush"  Color="#2860B8"/> <!-- Medium blue -->
    <SolidColorBrush x:Key="OllamaBrush"  Color="#206898"/> <!-- Teal-blue -->
    <SolidColorBrush x:Key="UserBrush"    Color="#386088"/> <!-- Slate blue -->
    <SolidColorBrush x:Key="AccentBrush"  Color="#3078D8"/> <!-- Clear sky blue -->

    <!-- Chat bubbles: soft blue-white tints -->
    <SolidColorBrush x:Key="ClaudeBubbleBrush" Color="#E8F0FA"/> <!-- Pale blue -->
    <SolidColorBrush x:Key="OllamaBubbleBrush" Color="#E4EEF8"/> <!-- Slightly cooler -->
    <SolidColorBrush x:Key="UserBubbleBrush"   Color="#EEF4FF"/> <!-- Near white with blue hint -->

</ResourceDictionary>
