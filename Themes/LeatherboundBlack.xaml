<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Leatherbound Black -->
    <!-- Chat-Fenster: altes Pergament  |  Rahmen: fast schwarzes, warmes Leder -->
    <SolidColorBrush x:Key="BackgroundBrush" Color="#F4E8CC"/> <!-- Gealtertes Pergament (Chat-Fläche) -->
    <SolidColorBrush x:Key="SidebarBrush"   Color="#1E1914"/> <!-- Fast schwarzes warmes Leder -->
    <SolidColorBrush x:Key="InputBrush"     Color="#352E26"/> <!-- Aufgehelltes Leder — Buttons, Karten -->
    <SolidColorBrush x:Key="SurfaceBrush"   Color="#453C32"/> <!-- Leicht helleres Leder — Oberflächen -->

    <!-- Text: dunkle Tinte auf Pergament — Blattgold auf Leder -->
    <SolidColorBrush x:Key="TextBrush"     Color="#160C04"/> <!-- Dunkle warme Tinte (lesbar auf Pergament) -->
    <SolidColorBrush x:Key="SubtextBrush"  Color="#D4AA3A"/> <!-- Blattgold (auf Leder-Bereichen) -->
    <SolidColorBrush x:Key="CardTextBrush"        Color="#D4AA3A"/> <!-- Blattgold auf Leder-Karten (Teilnehmer-Buttons) -->
    <SolidColorBrush x:Key="InputBackgroundBrush" Color="#F4E8CC"/> <!-- Pergament im Chat-Eingabefeld -->

    <!-- Akzente: warme Leder-Töne, aufgehellt — Bronze, Messing, Goldschnitt -->
    <SolidColorBrush x:Key="ClaudeBrush"  Color="#6A5A40"/> <!-- Warmes Dunkelgold/Bronze -->
    <SolidColorBrush x:Key="OllamaBrush"  Color="#504840"/> <!-- Gebranntes Lederbraun -->
    <SolidColorBrush x:Key="UserBrush"    Color="#807060"/> <!-- Helles Warmgrau-Leder -->
    <SolidColorBrush x:Key="AccentBrush"  Color="#A08858"/> <!-- Messing-Highlight -->

    <!-- Chat-Bubble-Hintergründe: Pergament-Variationen -->
    <SolidColorBrush x:Key="ClaudeBubbleBrush" Color="#EDE0C4"/> <!-- Warmes Amber-Pergament -->
    <SolidColorBrush x:Key="OllamaBubbleBrush" Color="#E8DCC0"/> <!-- Kühleres Pergament -->
    <SolidColorBrush x:Key="UserBubbleBrush"   Color="#F2EAD4"/> <!-- Cremiges Pergament -->

</ResourceDictionary>
