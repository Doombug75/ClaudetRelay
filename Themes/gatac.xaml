<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Gatac Manufacture — Xi'an-inspired human shipbuilder                   -->
    <!-- Brand: near-black with deep violet/purple + teal — sleek, alien-touch  -->
    <!-- Cockpit displays: purple/teal bioluminescent interface — Railen, Syulen -->

    <!-- Backgrounds — lacquered near-black, alien-cool darkness -->
    <SolidColorBrush x:Key="BackgroundBrush" Color="#080610"/> <!-- Void black, purple tint -->
    <SolidColorBrush x:Key="SidebarBrush"    Color="#05040C"/> <!-- Deeper void             -->
    <SolidColorBrush x:Key="InputBrush"      Color="#0E0C1C"/> <!-- Panel recess            -->
    <SolidColorBrush x:Key="SurfaceBrush"    Color="#18142C"/> <!-- Lacquered surface       -->

    <!-- Text — cool, slightly violet-tinted -->
    <SolidColorBrush x:Key="TextBrush"    Color="#C0B8D8"/> <!-- Cool violet-white        -->
    <SolidColorBrush x:Key="SubtextBrush" Color="#504898"/> <!-- Muted Gatac violet       -->

    <!-- Accents — Gatac deep violet, Xi'an teal, electric violet -->
    <SolidColorBrush x:Key="ClaudeBrush"  Color="#9060E0"/> <!-- Gatac signature violet   -->
    <SolidColorBrush x:Key="OllamaBrush"  Color="#18C0A0"/> <!-- Xi'an-inspired teal      -->
    <SolidColorBrush x:Key="UserBrush"    Color="#7060C8"/> <!-- Muted interface violet   -->
    <SolidColorBrush x:Key="AccentBrush"  Color="#C060FF"/> <!-- Electric violet — accent -->

    <!-- Bubble backgrounds — bioluminescent display tints -->
    <SolidColorBrush x:Key="ClaudeBubbleBrush" Color="#120A20"/> <!-- Deep violet          -->
    <SolidColorBrush x:Key="OllamaBubbleBrush" Color="#081818"/> <!-- Dark teal            -->
    <SolidColorBrush x:Key="UserBubbleBrush"   Color="#100C1E"/> <!-- Violet-dark          -->

</ResourceDictionary>
