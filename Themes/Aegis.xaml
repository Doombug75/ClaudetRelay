<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Aegis Dynamics — "Built for War"                                         -->
    <!-- Brand: gunmetal grey, military dark, targeting red/alert orange          -->
    <!-- Cockpit displays: dark grey with red targeting reticles, orange alerts   -->
    <!-- Ships: Hammerhead, Gladius, Vanguard, Eclipse, Idris                     -->

    <!-- Backgrounds — military grey steel, stealth bomber interior -->
    <SolidColorBrush x:Key="BackgroundBrush" Color="#0C0F14"/> <!-- Stealth gunmetal black  -->
    <SolidColorBrush x:Key="SidebarBrush"    Color="#080B0F"/> <!-- Armoured hull           -->
    <SolidColorBrush x:Key="InputBrush"      Color="#141820"/> <!-- Tactical panel recess   -->
    <SolidColorBrush x:Key="SurfaceBrush"    Color="#1E2530"/> <!-- Weapons console surface -->

    <!-- Text — cold, authoritative, military readout -->
    <SolidColorBrush x:Key="TextBrush"    Color="#C8D4DC"/> <!-- Cold military white      -->
    <SolidColorBrush x:Key="SubtextBrush" Color="#506070"/> <!-- Muted tactical grey      -->

    <!-- Accents — targeting red, alert orange, status blue -->
    <SolidColorBrush x:Key="ClaudeBrush"  Color="#C03028"/> <!-- Targeting reticle red    -->
    <SolidColorBrush x:Key="OllamaBrush"  Color="#6888A0"/> <!-- Gunmetal status blue     -->
    <SolidColorBrush x:Key="UserBrush"    Color="#4A7898"/> <!-- Comms channel blue       -->
    <SolidColorBrush x:Key="AccentBrush"  Color="#E05818"/> <!-- Alert orange — warning   -->

    <!-- Bubble backgrounds — targeting computer display tints -->
    <SolidColorBrush x:Key="ClaudeBubbleBrush" Color="#180A08"/> <!-- Dark red targeting   -->
    <SolidColorBrush x:Key="OllamaBubbleBrush" Color="#0C1018"/> <!-- Dark steel           -->
    <SolidColorBrush x:Key="UserBubbleBrush"   Color="#0A1018"/> <!-- Comms dark blue      -->

</ResourceDictionary>
