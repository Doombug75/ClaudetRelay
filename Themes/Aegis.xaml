<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Aegis - Hintergründe (Militärisch, stabil) -->
    <SolidColorBrush x:Key="BackgroundBrush" Color="#1E2438"/> <!-- Deep Navy Charcoal -->
    <SolidColorBrush x:Key="SidebarBrush" Color="#28304E"/>
    <SolidColorBrush x:Key="InputBrush" Color="#363F60"/>
    <SolidColorBrush x:Key="SurfaceBrush" Color="#4B5880"/>

    <!-- Aegis - Text (Klar, autoritär) -->
    <SolidColorBrush x:Key="TextBrush" Color="#C9DCE3"/>
    <SolidColorBrush x:Key="SubtextBrush" Color="#9AADC0"/>

    <!-- Aegis - Akzente (Standardisiert, militärisch) -->
    <SolidColorBrush x:Key="ClaudeBrush" Color="#708090"/> <!-- Slate Steel Grey -->
    <SolidColorBrush x:Key="OllamaBrush" Color="#6A9E80"/> <!-- Deep Military Teal -->
    <SolidColorBrush x:Key="UserBrush" Color="#9CB3FF"/> <!-- Official Light Blue -->
    <SolidColorBrush x:Key="AccentBrush" Color="#D9534F"/> <!-- Emergency Red -->

    <!-- Aegis - Bubble Hintergründe -->
    <SolidColorBrush x:Key="ClaudeBubbleBrush" Color="#1F263A"/>
    <SolidColorBrush x:Key="OllamaBubbleBrush" Color="#19202C"/>
    <SolidColorBrush x:Key="UserBubbleBrush" Color="#1D2235"/>

</ResourceDictionary>





