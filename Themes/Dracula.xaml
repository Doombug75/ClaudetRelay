<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Dracula - Backgrounds -->
    <SolidColorBrush x:Key="BackgroundBrush" Color="#282A36"/>
    <SolidColorBrush x:Key="SidebarBrush"    Color="#21222C"/>
    <SolidColorBrush x:Key="InputBrush"      Color="#343746"/>
    <SolidColorBrush x:Key="SurfaceBrush"    Color="#44475A"/>

    <!-- Dracula - Text -->
    <SolidColorBrush x:Key="TextBrush"    Color="#F8F8F2"/>
    <SolidColorBrush x:Key="SubtextBrush" Color="#6272A4"/>

    <!-- Dracula - Accents -->
    <SolidColorBrush x:Key="ClaudeBrush"  Color="#BD93F9"/> <!-- Dracula Purple -->
    <SolidColorBrush x:Key="OllamaBrush"  Color="#50FA7B"/> <!-- Dracula Green  -->
    <SolidColorBrush x:Key="UserBrush"    Color="#8BE9FD"/> <!-- Dracula Cyan   -->
    <SolidColorBrush x:Key="AccentBrush"  Color="#FF79C6"/> <!-- Dracula Pink   -->

    <!-- Dracula - Bubble Backgrounds -->
    <SolidColorBrush x:Key="ClaudeBubbleBrush" Color="#241E38"/>
    <SolidColorBrush x:Key="OllamaBubbleBrush" Color="#1A2E1F"/>
    <SolidColorBrush x:Key="UserBubbleBrush"   Color="#192632"/>

</ResourceDictionary>
