<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Cosmic Noir - Hintergründe -->
    <SolidColorBrush x:Key="BackgroundBrush" Color="#0A0B1A"/>
    <SolidColorBrush x:Key="SidebarBrush" Color="#141625"/>
    <SolidColorBrush x:Key="InputBrush" Color="#1C1F35"/>
    <SolidColorBrush x:Key="SurfaceBrush" Color="#25294A"/>

    <!-- Cosmic Noir - Text -->
    <SolidColorBrush x:Key="TextBrush" Color="#D9E2FE"/>
    <SolidColorBrush x:Key="SubtextBrush" Color="#7781B5"/>

    <!-- Cosmic Noir - Akzente -->
    <SolidColorBrush x:Key="ClaudeBrush" Color="#9C7EF5"/> <!-- Electric Purple -->
    <SolidColorBrush x:Key="OllamaBrush" Color="#42C4A7"/> <!-- Teal Green -->
    <SolidColorBrush x:Key="UserBrush" Color="#89B4FA"/> <!-- Sky Blue -->
    <SolidColorBrush x:Key="AccentBrush" Color="#F472B6"/> <!-- Magenta Accent -->

    <!-- Cosmic Noir - Bubble Hintergründe -->
    <SolidColorBrush x:Key="ClaudeBubbleBrush" Color="#151830"/>
    <SolidColorBrush x:Key="OllamaBubbleBrush" Color="#102520"/>
    <SolidColorBrush x:Key="UserBubbleBrush" Color="#121630"/>

</ResourceDictionary>
