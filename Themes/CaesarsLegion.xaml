<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Caesar's Legion — "Ave, Caesar!"                                          -->
    <!-- Brand: imperial crimson, legionnaire brass, Roman authority               -->
    <!-- Aesthetic: blood and sand, brutal order, slave-forged empire              -->

    <!-- Backgrounds — dark crimson-black, desert night -->
    <SolidColorBrush x:Key="BackgroundBrush" Color="#0E0608"/> <!-- Dark crimson-void         -->
    <SolidColorBrush x:Key="SidebarBrush"    Color="#0A0406"/> <!-- Deeper imperial black     -->
    <SolidColorBrush x:Key="InputBrush"      Color="#160C0A"/> <!-- Panel recess              -->
    <SolidColorBrush x:Key="SurfaceBrush"    Color="#201010"/> <!-- Leather/blood surface     -->

    <!-- Text — sun-scorched sand, desert parchment -->
    <SolidColorBrush x:Key="TextBrush"    Color="#D4C098"/> <!-- Desert parchment          -->
    <SolidColorBrush x:Key="SubtextBrush" Color="#804840"/> <!-- Muted blood-dust          -->

    <!-- Accents — Legion crimson, legionnaire brass, worn bronze -->
    <SolidColorBrush x:Key="ClaudeBrush"  Color="#C02818"/> <!-- Legion crimson — centurion -->
    <SolidColorBrush x:Key="OllamaBrush"  Color="#C8900C"/> <!-- Legionnaire brass         -->
    <SolidColorBrush x:Key="UserBrush"    Color="#A05828"/> <!-- Worn leather/bronze       -->
    <SolidColorBrush x:Key="AccentBrush"  Color="#E03020"/> <!-- Blood red — "Ave, Caesar!"-->

    <!-- Bubble backgrounds — blood and sand tints -->
    <SolidColorBrush x:Key="ClaudeBubbleBrush" Color="#180808"/> <!-- Deep crimson          -->
    <SolidColorBrush x:Key="OllamaBubbleBrush" Color="#181008"/> <!-- Dark brass            -->
    <SolidColorBrush x:Key="UserBubbleBrush"   Color="#180C08"/> <!-- Leather dark          -->

</ResourceDictionary>
