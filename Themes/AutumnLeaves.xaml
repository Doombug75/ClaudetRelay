<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Autumn Leaves - Backgrounds -->
    <SolidColorBrush x:Key="BackgroundBrush" Color="#1A1208"/>
    <SolidColorBrush x:Key="SidebarBrush"    Color="#120D05"/>
    <SolidColorBrush x:Key="InputBrush"      Color="#2A1D0F"/>
    <SolidColorBrush x:Key="SurfaceBrush"    Color="#3D2812"/>

    <!-- Autumn Leaves - Text -->
    <SolidColorBrush x:Key="TextBrush"    Color="#F4D499"/>
    <SolidColorBrush x:Key="SubtextBrush" Color="#8B6535"/>

    <!-- Autumn Leaves - Accents -->
    <SolidColorBrush x:Key="ClaudeBrush"  Color="#E07B39"/> <!-- Pumpkin Orange -->
    <SolidColorBrush x:Key="OllamaBrush"  Color="#C9A82C"/> <!-- Golden Yellow  -->
    <SolidColorBrush x:Key="UserBrush"    Color="#D4503A"/> <!-- Maple Red      -->
    <SolidColorBrush x:Key="AccentBrush"  Color="#E8963F"/> <!-- Amber          -->

    <!-- Autumn Leaves - Bubble Backgrounds -->
    <SolidColorBrush x:Key="ClaudeBubbleBrush" Color="#281808"/>
    <SolidColorBrush x:Key="OllamaBubbleBrush" Color="#261A08"/>
    <SolidColorBrush x:Key="UserBubbleBrush"   Color="#271008"/>

</ResourceDictionary>
