<Window x:Class="ClaudetRelay.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ClaudetRelay" Height="820" Width="1220"
        MinHeight="600" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource BackgroundBrush}">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- Theme is loaded dynamically from the Themes folder at startup -->
            </ResourceDictionary.MergedDictionaries>

            <!-- Base button -->
            <Style x:Key="ModernButton" TargetType="Button">
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="FontFamily" Value="Segoe UI"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="Padding" Value="14,9"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="8"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Opacity" Value="0.82"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="Bd" Property="Opacity" Value="0.65"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="SendButton" TargetType="Button" BasedOn="{StaticResource ModernButton}">
                <Setter Property="Background" Value="{DynamicResource ClaudeBrush}"/>
                <Setter Property="Foreground" Value="{DynamicResource SidebarBrush}"/>
                <Setter Property="FontWeight" Value="Bold"/>
            </Style>

            <Style x:Key="SidebarButton" TargetType="Button" BasedOn="{StaticResource ModernButton}">
                <Setter Property="Background" Value="{DynamicResource InputBrush}"/>
                <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
                <Setter Property="HorizontalAlignment" Value="Stretch"/>
                <Setter Property="Padding" Value="12,9"/>
            </Style>

            <!-- Tab button (Chat / Projects) -->
            <Style x:Key="TabButton" TargetType="Button">
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="FontFamily" Value="Segoe UI"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="Padding" Value="16,8,16,10"/>
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="8,8,0,0"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Opacity" Value="0.8"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- ComboBox — full custom template for theme-safe readability -->
            <Style x:Key="ModernComboBox" TargetType="ComboBox">
                <Setter Property="Background"      Value="{DynamicResource InputBrush}"/>
                <Setter Property="Foreground"      Value="{DynamicResource TextBrush}"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Height"          Value="36"/>
                <Setter Property="FontSize"        Value="13"/>
                <Setter Property="FontFamily"      Value="Segoe UI"/>
                <Setter Property="Cursor"          Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ComboBox">
                            <Grid>
                                <ToggleButton x:Name="ToggleButton"
                                              IsChecked="{Binding IsDropDownOpen, Mode=TwoWay,
                                                          RelativeSource={RelativeSource TemplatedParent}}"
                                              Focusable="False" ClickMode="Press"
                                              BorderThickness="0" Cursor="Hand">
                                    <ToggleButton.Template>
                                        <ControlTemplate TargetType="ToggleButton">
                                            <Border x:Name="Bd"
                                                    Background="{DynamicResource InputBrush}"
                                                    CornerRadius="8">
                                                <TextBlock Text="▾" FontSize="11"
                                                           Foreground="{DynamicResource SubtextBrush}"
                                                           HorizontalAlignment="Right"
                                                           VerticalAlignment="Center"
                                                           Margin="0,0,10,0"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd" Property="Opacity" Value="0.82"/>
                                                </Trigger>
                                                <Trigger Property="IsChecked" Value="True">
                                                    <Setter TargetName="Bd" Property="Opacity" Value="0.90"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </ToggleButton.Template>
                                </ToggleButton>

                                <ContentPresenter IsHitTestVisible="False"
                                                  Content="{TemplateBinding SelectionBoxItem}"
                                                  ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                  Margin="12,0,30,0"
                                                  VerticalAlignment="Center"
                                                  HorizontalAlignment="Left"/>

                                <Popup x:Name="PART_Popup"
                                       Placement="Bottom"
                                       IsOpen="{TemplateBinding IsDropDownOpen}"
                                       AllowsTransparency="True"
                                       Focusable="False"
                                       PopupAnimation="Slide">
                                    <Border MinWidth="{TemplateBinding ActualWidth}"
                                            MaxHeight="320"
                                            Background="{DynamicResource SurfaceBrush}"
                                            BorderBrush="{DynamicResource InputBrush}"
                                            BorderThickness="1"
                                            CornerRadius="8"
                                            Margin="0,3,0,0"
                                            SnapsToDevicePixels="True">
                                        <Border.Effect>
                                            <DropShadowEffect Color="#000000" Opacity="0.50"
                                                              BlurRadius="20" ShadowDepth="4"/>
                                        </Border.Effect>
                                        <ScrollViewer Margin="4" CanContentScroll="True"
                                                      VerticalScrollBarVisibility="Auto">
                                            <StackPanel IsItemsHost="True"
                                                        KeyboardNavigation.DirectionalNavigation="Contained"/>
                                        </ScrollViewer>
                                    </Border>
                                </Popup>
                            </Grid>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
                <Setter Property="ItemContainerStyle">
                    <Setter.Value>
                        <Style TargetType="ComboBoxItem">
                            <Setter Property="Foreground"  Value="{DynamicResource TextBrush}"/>
                            <Setter Property="Background"  Value="Transparent"/>
                            <Setter Property="Padding"     Value="10,7"/>
                            <Setter Property="FontSize"    Value="13"/>
                            <Setter Property="FontFamily"  Value="Segoe UI"/>
                            <Setter Property="Cursor"      Value="Hand"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ComboBoxItem">
                                        <Border x:Name="Bd"
                                                Background="{TemplateBinding Background}"
                                                CornerRadius="6" Margin="3,1"
                                                Padding="{TemplateBinding Padding}">
                                            <ContentPresenter/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsHighlighted" Value="True">
                                                <Setter TargetName="Bd" Property="Background"
                                                        Value="{DynamicResource InputBrush}"/>
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="Bd" Property="Background"
                                                        Value="{DynamicResource InputBrush}"/>
                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Popup model list: ListBoxItem style -->
            <Style x:Key="ModelListItem" TargetType="ListBoxItem">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
                <Setter Property="Padding" Value="8,6"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="FontFamily" Value="Segoe UI"/>
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ListBoxItem">
                            <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                    CornerRadius="6" Padding="{TemplateBinding Padding}">
                                <ContentPresenter/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background"
                                            Value="{DynamicResource SurfaceBrush}"/>
                                </Trigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter TargetName="Bd" Property="Background"
                                            Value="{DynamicResource InputBrush}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Toggle switch (CheckBox used as enable/disable toggle) -->
            <Style x:Key="ToggleSwitch" TargetType="CheckBox">
                <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="FontFamily" Value="Segoe UI"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="VerticalContentAlignment" Value="Center"/>
            </Style>

        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="264"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ══════════════════════════ SIDEBAR ══════════════════════════ -->
        <Border Grid.Column="0" Background="{DynamicResource SidebarBrush}">
            <DockPanel>

                <!-- Footer -->
                <StackPanel DockPanel.Dock="Bottom" Margin="14,0,14,16">
                    <Rectangle Height="1" Fill="{DynamicResource InputBrush}" Margin="0,0,0,12"/>
                    <Button Content="⚙  Settings"
                            Style="{StaticResource SidebarButton}"
                            Margin="0,0,0,7"
                            Click="SettingsButton_Click"/>
                    <Button Content="🗑  Clear Chat"
                            Style="{StaticResource SidebarButton}"
                            Click="ClearChat_Click"/>
                </StackPanel>

                <!-- Scrollable content -->
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Margin="14,20,14,8">

                        <!-- ── Logo ── -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,28">
                            <Border Width="38" Height="38" CornerRadius="10"
                                    Background="{DynamicResource ClaudeBrush}" Margin="0,0,10,0">
                                <TextBlock Text="CR" FontSize="14" FontWeight="Bold"
                                           Foreground="{DynamicResource SidebarBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock FontSize="17" FontWeight="Bold" FontFamily="Segoe UI">
                                    <Run Text="Claudet" Foreground="{DynamicResource ClaudeBrush}"/>
                                    <Run Text=" "/><Run Text="Relay" Foreground="{DynamicResource UserBrush}"/>
                                </TextBlock>
                                <TextBlock Text="Multi-AI Chat" FontSize="10"
                                           Foreground="{DynamicResource SubtextBrush}"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- ── Participants ── -->
                        <TextBlock Text="PARTICIPANTS" FontSize="10" FontWeight="Bold"
                                   Foreground="{DynamicResource SubtextBrush}" Margin="2,0,0,10"/>

                        <!-- ── Cloud AI cards (dynamic) ── -->
                        <StackPanel x:Name="CloudAICardsPanel"/>

                        <Button x:Name="AddCloudAIButton"
                                Content="+ Add Cloud AI"
                                Style="{StaticResource SidebarButton}"
                                Foreground="{DynamicResource ClaudeBrush}"
                                Margin="0,0,0,7"
                                Click="AddCloudAIButton_Click"/>

                        <!-- ── Ollama cards (dynamic) ── -->
                        <StackPanel x:Name="OllamaCardsPanel"/>

                        <Button x:Name="AddOllamaButton"
                                Content="+ Add Ollama"
                                Style="{StaticResource SidebarButton}"
                                Foreground="{DynamicResource OllamaBrush}"
                                Margin="0,0,0,7"
                                Click="AddOllamaButton_Click"/>

                        <!-- ── Theme ── -->
                        <TextBlock Text="THEME" FontSize="10" FontWeight="Bold"
                                   Foreground="{DynamicResource SubtextBrush}" Margin="2,0,0,10"/>
                        <ComboBox x:Name="ThemeComboBox"
                                  Style="{StaticResource ModernComboBox}"
                                  SelectionChanged="ThemeComboBox_SelectionChanged"/>

                        <!-- ══ Add Cloud AI popup ══ -->
                        <Popup x:Name="AddCloudAIPopup"
                               PlacementTarget="{Binding ElementName=AddCloudAIButton}"
                               Placement="Right" HorizontalOffset="10" VerticalOffset="-8"
                               StaysOpen="False" AllowsTransparency="True">
                            <Border Background="{DynamicResource SidebarBrush}"
                                    BorderBrush="{DynamicResource SurfaceBrush}"
                                    BorderThickness="1" CornerRadius="12"
                                    Padding="14" MinWidth="230">
                                <Border.Effect>
                                    <DropShadowEffect Color="#000000" Opacity="0.45"
                                                      BlurRadius="22" ShadowDepth="4"/>
                                </Border.Effect>
                                <StackPanel>
                                    <TextBlock Text="Add Cloud AI" FontSize="13" FontWeight="SemiBold"
                                               Foreground="{DynamicResource ClaudeBrush}"
                                               Margin="0,0,0,8"/>
                                    <Rectangle Height="1" Fill="{DynamicResource InputBrush}"
                                               Margin="0,0,0,10"/>
                                    <TextBlock Text="PROVIDER" FontSize="10" FontWeight="Bold"
                                               Foreground="{DynamicResource SubtextBrush}"
                                               Margin="2,0,0,6"/>
                                    <ComboBox x:Name="AddCloudAIProviderCombo"
                                              Style="{StaticResource ModernComboBox}"
                                              Margin="0,0,0,10"
                                              SelectionChanged="AddCloudAIProviderCombo_SelectionChanged">
                                        <ComboBoxItem Content="Anthropic"/>
                                        <ComboBoxItem Content="Google AI"/>
                                        <ComboBoxItem Content="Groq"/>
                                        <ComboBoxItem Content="OpenRouter"/>
                                        <ComboBoxItem Content="Mistral"/>
                                    </ComboBox>
                                    <TextBlock Text="MODEL" FontSize="10" FontWeight="Bold"
                                               Foreground="{DynamicResource SubtextBrush}"
                                               Margin="2,0,0,6"/>
                                    <ComboBox x:Name="AddCloudAIModelCombo"
                                              Style="{StaticResource ModernComboBox}"
                                              Margin="0,0,0,14"/>
                                    <Button Content="Add to Chat"
                                            x:Name="ConfirmAddCloudAIButton"
                                            Style="{StaticResource SidebarButton}"
                                            Foreground="{DynamicResource ClaudeBrush}"
                                            Click="ConfirmAddCloudAI_Click"/>
                                </StackPanel>
                            </Border>
                        </Popup>

                    </StackPanel>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- ══════════════════════════ MAIN AREA ══════════════════════════ -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>  <!-- Row 0: Tab bar -->
                <RowDefinition Height="Auto"/>  <!-- Row 1: Chat header (hidden in Projects tab) -->
                <RowDefinition Height="*"/>     <!-- Row 2: Content (chat or projects) -->
                <RowDefinition Height="Auto"/>  <!-- Row 3: Input (hidden in Projects tab) -->
            </Grid.RowDefinitions>

            <!-- ── Tab bar (Row 0) ── -->
            <Border Grid.Row="0" Background="{DynamicResource SidebarBrush}"
                    Padding="12,6,22,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <Button x:Name="ChatTabButton"
                                Content="💬  Chat"
                                Style="{StaticResource TabButton}"
                                FontWeight="SemiBold"
                                Click="ChatTabButton_Click">
                            <Button.Foreground>
                                <DynamicResource ResourceKey="TextBrush"/>
                            </Button.Foreground>
                            <Button.Background>
                                <DynamicResource ResourceKey="InputBrush"/>
                            </Button.Background>
                        </Button>
                        <Button x:Name="ProjectsTabButton"
                                Content="📁  Projects"
                                Style="{StaticResource TabButton}"
                                Click="ProjectsTabButton_Click">
                            <Button.Foreground>
                                <DynamicResource ResourceKey="SubtextBrush"/>
                            </Button.Foreground>
                        </Button>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Bottom"
                                Margin="0,0,0,8">
                        <Ellipse Width="9" Height="9" Fill="{DynamicResource ClaudeBrush}" Margin="0,0,5,0"/>
                        <Ellipse Width="9" Height="9" Fill="{DynamicResource OllamaBrush}" Margin="0,0,5,0"/>
                        <Ellipse Width="9" Height="9" Fill="{DynamicResource UserBrush}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ── Chat header (Row 1) ── -->
            <Border x:Name="ChatHeader" Grid.Row="1"
                    Background="{DynamicResource SidebarBrush}" Padding="22,13">
                <TextBlock x:Name="ChatHeaderTitle"
                           Text="Chat"
                           FontSize="15" FontWeight="SemiBold"
                           FontFamily="Segoe UI"
                           Foreground="{DynamicResource TextBrush}"/>
            </Border>
            <Rectangle x:Name="ChatHeaderSep" Grid.Row="1" Height="1" VerticalAlignment="Bottom"
                       Fill="{DynamicResource InputBrush}"/>

            <!-- ── Content area (Row 2) — Chat and Projects layered ── -->

            <!-- Chat scrollviewer -->
            <ScrollViewer x:Name="ChatScrollViewer" Grid.Row="2"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Padding="20,12,20,12">
                <StackPanel x:Name="ChatPanel"/>
            </ScrollViewer>

            <!-- Projects panel (hidden in Chat mode) -->
            <Grid x:Name="ProjectsContent" Grid.Row="2" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Projects subheader -->
                <Border Grid.Row="0" Background="{DynamicResource SidebarBrush}" Padding="22,13">
                    <TextBlock Text="Projects" FontSize="15" FontWeight="SemiBold"
                               FontFamily="Segoe UI" Foreground="{DynamicResource TextBrush}"/>
                </Border>
                <Rectangle Grid.Row="0" Height="1" VerticalAlignment="Bottom"
                           Fill="{DynamicResource InputBrush}"/>

                <!-- Project list -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Padding="20,16,20,16">
                    <StackPanel x:Name="ProjectListPanel"/>
                </ScrollViewer>

                <!-- Project action bar -->
                <Border Grid.Row="2" Background="{DynamicResource SidebarBrush}" Padding="16,12,16,16">
                    <StackPanel>
                        <Rectangle Height="1" Fill="{DynamicResource InputBrush}" Margin="0,0,0,12"/>
                        <StackPanel Orientation="Horizontal">
                            <Button Content="+ New Project"
                                    x:Name="NewProjectButton"
                                    Style="{StaticResource ModernButton}"
                                    Background="{DynamicResource InputBrush}"
                                    Foreground="{DynamicResource ClaudeBrush}"
                                    Margin="0,0,8,0"
                                    Click="NewProject_Click"/>
                            <Button Content="Open"
                                    x:Name="OpenProjectButton"
                                    Style="{StaticResource ModernButton}"
                                    Background="{DynamicResource InputBrush}"
                                    Foreground="{DynamicResource TextBrush}"
                                    IsEnabled="False"
                                    Margin="0,0,8,0"
                                    Click="OpenProject_Click"/>
                            <Button Content="Delete"
                                    x:Name="DeleteProjectButton"
                                    Style="{StaticResource ModernButton}"
                                    Background="{DynamicResource InputBrush}"
                                    Foreground="{DynamicResource AccentBrush}"
                                    IsEnabled="False"
                                    Click="DeleteProject_Click"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- ── Input (Row 3) ── -->
            <Border x:Name="InputArea" Grid.Row="3"
                    Background="{DynamicResource SidebarBrush}" Padding="16,12,16,16">
                <StackPanel>
                    <Rectangle Height="1" Fill="{DynamicResource InputBrush}" Margin="0,0,0,12"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Background="{DynamicResource InputBrush}"
                                CornerRadius="12" Margin="0,0,10,0">
                            <Grid Margin="14,10,14,10">
                                <TextBox x:Name="InputTextBox"
                                         Background="Transparent"
                                         Foreground="{DynamicResource TextBrush}"
                                         BorderThickness="0" FontSize="13" FontFamily="Segoe UI"
                                         TextWrapping="Wrap" AcceptsReturn="False" MaxLines="8"
                                         VerticalContentAlignment="Top"
                                         VerticalScrollBarVisibility="Disabled"
                                         Padding="0,2,0,2"
                                         CaretBrush="{DynamicResource TextBrush}"
                                         SelectionBrush="{DynamicResource ClaudeBrush}"
                                         KeyDown="InputTextBox_KeyDown"
                                         TextChanged="InputTextBox_TextChanged"/>
                                <TextBlock x:Name="PlaceholderText"
                                           Text="Type a message...  (Enter ↵ send  •  Shift+Enter for new line)"
                                           Foreground="{DynamicResource SubtextBrush}"
                                           FontSize="13" FontFamily="Segoe UI"
                                           VerticalAlignment="Top" Margin="0,2,0,0"
                                           IsHitTestVisible="False"/>
                            </Grid>
                        </Border>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Bottom">
                            <Button x:Name="SendButton" Content="Send"
                                    Style="{StaticResource SendButton}"
                                    MinWidth="82" Margin="0,0,8,0"
                                    Click="SendButton_Click"/>
                            <Button x:Name="AIRespondButton" Content="↺ Re-Send"
                                    Style="{StaticResource ModernButton}"
                                    Background="{DynamicResource OllamaBrush}"
                                    Foreground="{DynamicResource SidebarBrush}"
                                    FontWeight="Bold" MinWidth="62"
                                    Click="AIRespond_Click"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
