<Window x:Class="ClaudetRelay.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ClaudetRelay" Height="820" Width="1220"
        MinHeight="600" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource BackgroundBrush}">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Themes/CatppuccinMocha.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- Basis-Button -->
            <Style x:Key="ModernButton" TargetType="Button">
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="FontFamily" Value="Segoe UI"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="Padding" Value="14,9"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="8"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Opacity" Value="0.82"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="Bd" Property="Opacity" Value="0.65"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Senden-Button -->
            <Style x:Key="SendButton" TargetType="Button" BasedOn="{StaticResource ModernButton}">
                <Setter Property="Background" Value="{DynamicResource ClaudeBrush}"/>
                <Setter Property="Foreground" Value="{DynamicResource SidebarBrush}"/>
                <Setter Property="FontWeight" Value="Bold"/>
            </Style>

            <!-- Sidebar-Button -->
            <Style x:Key="SidebarButton" TargetType="Button" BasedOn="{StaticResource ModernButton}">
                <Setter Property="Background" Value="{DynamicResource InputBrush}"/>
                <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
                <Setter Property="HorizontalAlignment" Value="Stretch"/>
                <Setter Property="Padding" Value="12,9"/>
            </Style>

            <!-- ComboBox -->
            <ControlTemplate x:Key="ComboBoxToggleButton" TargetType="ToggleButton">
                <Border Background="{DynamicResource InputBrush}" CornerRadius="8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="28"/>
                        </Grid.ColumnDefinitions>
                        <ContentPresenter Grid.Column="0" Margin="10,0,0,0"
                                          VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="▾" FontSize="11"
                                   Foreground="{DynamicResource SubtextBrush}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Grid>
                </Border>
            </ControlTemplate>

            <Style x:Key="ModernComboBox" TargetType="ComboBox">
                <Setter Property="Background" Value="{DynamicResource InputBrush}"/>
                <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Height" Value="36"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="FontFamily" Value="Segoe UI"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="ItemContainerStyle">
                    <Setter.Value>
                        <Style TargetType="ComboBoxItem">
                            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
                            <Setter Property="Background" Value="{DynamicResource SidebarBrush}"/>
                            <Setter Property="Padding" Value="10,8"/>
                            <Setter Property="FontSize" Value="13"/>
                            <Style.Triggers>
                                <Trigger Property="IsHighlighted" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource InputBrush}"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Setter.Value>
                </Setter>
            </Style>

        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="264"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ══════════════════════════ SIDEBAR ══════════════════════════ -->
        <Border Grid.Column="0" Background="{DynamicResource SidebarBrush}">
            <DockPanel>

                <!-- Footer (unten fixiert) -->
                <StackPanel DockPanel.Dock="Bottom" Margin="14,0,14,16">
                    <Rectangle Height="1" Fill="{DynamicResource InputBrush}" Margin="0,0,0,12"/>
                    <Button Content="⚙  Einstellungen"
                            Style="{StaticResource SidebarButton}"
                            Margin="0,0,0,7"
                            Click="SettingsButton_Click"/>
                    <Button Content="🗑  Chat leeren"
                            Style="{StaticResource SidebarButton}"
                            Click="ClearChat_Click"/>
                </StackPanel>

                <!-- Scrollbarer Sidebar-Inhalt -->
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Margin="14,20,14,8">

                        <!-- ── Logo ── -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,28">
                            <Border Width="38" Height="38" CornerRadius="10"
                                    Background="{DynamicResource ClaudeBrush}"
                                    Margin="0,0,10,0">
                                <TextBlock Text="CR" FontSize="14" FontWeight="Bold"
                                           Foreground="{DynamicResource SidebarBrush}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock FontSize="17" FontWeight="Bold" FontFamily="Segoe UI">
                                    <Run Text="Claudet" Foreground="{DynamicResource ClaudeBrush}"/>
                                    <Run Text=" "/><Run Text="Relay" Foreground="{DynamicResource UserBrush}"/>
                                </TextBlock>
                                <TextBlock Text="Multi-AI Chat" FontSize="10"
                                           Foreground="{DynamicResource SubtextBrush}"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- ── Teilnehmer ── -->
                        <TextBlock Text="TEILNEHMER" FontSize="10" FontWeight="Bold"
                                   Foreground="{DynamicResource SubtextBrush}"
                                   Margin="2,0,0,10"/>

                        <!-- Claude -->
                        <Border Background="{DynamicResource InputBrush}" CornerRadius="10"
                                Padding="10" Margin="0,0,0,7">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Width="34" Height="34" CornerRadius="9"
                                        Background="{DynamicResource ClaudeBrush}"
                                        Margin="0,0,10,0">
                                    <TextBlock Text="C" FontSize="15" FontWeight="Bold"
                                               Foreground="{DynamicResource SidebarBrush}"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="Claude" FontSize="13" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextBrush}"/>
                                    <TextBlock Text="Anthropic API" FontSize="10"
                                               Foreground="{DynamicResource SubtextBrush}"/>
                                </StackPanel>
                                <Ellipse Grid.Column="2" Width="8" Height="8"
                                         Fill="{DynamicResource OllamaBrush}"
                                         VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <!-- Ollama -->
                        <Border Background="{DynamicResource InputBrush}" CornerRadius="10"
                                Padding="10" Margin="0,0,0,7">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Width="34" Height="34" CornerRadius="9"
                                        Background="{DynamicResource OllamaBrush}"
                                        Margin="0,0,10,0">
                                    <TextBlock Text="O" FontSize="15" FontWeight="Bold"
                                               Foreground="{DynamicResource SidebarBrush}"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="Ollama" FontSize="13" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextBrush}"/>
                                    <TextBlock x:Name="OllamaModelLabel" Text="llama3.2" FontSize="10"
                                               Foreground="{DynamicResource SubtextBrush}"/>
                                </StackPanel>
                                <Ellipse Grid.Column="2" Width="8" Height="8"
                                         Fill="{DynamicResource OllamaBrush}"
                                         VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <!-- User -->
                        <Border Background="{DynamicResource InputBrush}" CornerRadius="10"
                                Padding="10" Margin="0,0,0,26">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Width="34" Height="34" CornerRadius="9"
                                        Background="{DynamicResource UserBrush}"
                                        Margin="0,0,10,0">
                                    <TextBlock Text="U" FontSize="15" FontWeight="Bold"
                                               Foreground="{DynamicResource SidebarBrush}"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="Du" FontSize="13" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextBrush}"/>
                                    <TextBlock Text="Benutzer" FontSize="10"
                                               Foreground="{DynamicResource SubtextBrush}"/>
                                </StackPanel>
                                <Ellipse Grid.Column="2" Width="8" Height="8"
                                         Fill="{DynamicResource OllamaBrush}"
                                         VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <!-- ── Theme ── -->
                        <TextBlock Text="DESIGN" FontSize="10" FontWeight="Bold"
                                   Foreground="{DynamicResource SubtextBrush}"
                                   Margin="2,0,0,10"/>

                        <TextBlock Text="Catppuccin Theme" FontSize="11"
                                   Foreground="{DynamicResource SubtextBrush}"
                                   Margin="2,0,0,6"/>

                        <ComboBox x:Name="ThemeComboBox"
                                  Style="{StaticResource ModernComboBox}"
                                  SelectionChanged="ThemeComboBox_SelectionChanged">
                            <ComboBoxItem Content="🌙  Mocha  (dunkel)" Tag="Mocha" IsSelected="True"/>
                            <ComboBoxItem Content="🌟  Macchiato  (dunkel)" Tag="Macchiato"/>
                            <ComboBoxItem Content="☁  Frappé  (mittel)" Tag="Frappe"/>
                            <ComboBoxItem Content="☀  Latte  (hell)" Tag="Latte"/>
                        </ComboBox>

                    </StackPanel>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- ══════════════════════════ HAUPTBEREICH ══════════════════════════ -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- ── Header ── -->
            <Border Grid.Row="0" Background="{DynamicResource SidebarBrush}"
                    Padding="22,13">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Chat-Verlauf" FontSize="15" FontWeight="SemiBold"
                                   FontFamily="Segoe UI"
                                   Foreground="{DynamicResource TextBrush}"/>
                        <TextBlock Text="Claude · Ollama · Du" FontSize="11"
                                   FontFamily="Segoe UI"
                                   Foreground="{DynamicResource SubtextBrush}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <Ellipse Width="9" Height="9"
                                 Fill="{DynamicResource ClaudeBrush}" Margin="0,0,5,0"/>
                        <Ellipse Width="9" Height="9"
                                 Fill="{DynamicResource OllamaBrush}" Margin="0,0,5,0"/>
                        <Ellipse Width="9" Height="9"
                                 Fill="{DynamicResource UserBrush}"/>
                    </StackPanel>
                </Grid>
            </Border>
            <Rectangle Grid.Row="0" Height="1" VerticalAlignment="Bottom"
                       Fill="{DynamicResource InputBrush}"/>

            <!-- ── Chat-Verlauf ── -->
            <ScrollViewer Grid.Row="1" x:Name="ChatScrollViewer"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Padding="20,12,20,12">
                <StackPanel x:Name="ChatPanel"/>
            </ScrollViewer>

            <!-- ── Eingabebereich ── -->
            <Border Grid.Row="2" Background="{DynamicResource SidebarBrush}"
                    Padding="16,12,16,16">
                <StackPanel>
                    <Rectangle Height="1" Fill="{DynamicResource InputBrush}" Margin="0,0,0,12"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Texteingabe -->
                        <Border Grid.Column="0"
                                Background="{DynamicResource InputBrush}"
                                CornerRadius="12"
                                Margin="0,0,10,0">
                            <Grid Margin="14,10,14,10">
                                <TextBox x:Name="InputTextBox"
                                         Background="Transparent"
                                         Foreground="{DynamicResource TextBrush}"
                                         BorderThickness="0"
                                         FontSize="13"
                                         FontFamily="Segoe UI"
                                         TextWrapping="Wrap"
                                         AcceptsReturn="False"
                                         MaxLines="5"
                                         VerticalContentAlignment="Center"
                                         CaretBrush="{DynamicResource TextBrush}"
                                         SelectionBrush="{DynamicResource ClaudeBrush}"
                                         KeyDown="InputTextBox_KeyDown"
                                         TextChanged="InputTextBox_TextChanged"/>
                                <TextBlock x:Name="PlaceholderText"
                                           Text="Nachricht eingeben…  (Enter zum Senden)"
                                           Foreground="{DynamicResource SubtextBrush}"
                                           FontSize="13"
                                           FontFamily="Segoe UI"
                                           VerticalAlignment="Center"
                                           IsHitTestVisible="False"/>
                            </Grid>
                        </Border>

                        <!-- Aktions-Buttons -->
                        <StackPanel Grid.Column="1" Orientation="Horizontal"
                                    VerticalAlignment="Bottom">
                            <Button x:Name="SendButton"
                                    Content="Senden"
                                    Style="{StaticResource SendButton}"
                                    MinWidth="82"
                                    Margin="0,0,8,0"
                                    Click="SendButton_Click"/>
                            <Button x:Name="AIRespondButton"
                                    Content="KI ▶"
                                    Style="{StaticResource ModernButton}"
                                    Background="{DynamicResource OllamaBrush}"
                                    Foreground="{DynamicResource SidebarBrush}"
                                    FontWeight="Bold"
                                    MinWidth="62"
                                    Click="AIRespond_Click"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
