<Window x:Class="ClaudetRelay.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ClaudetRelay" Height="820" Width="1220"
        MinHeight="600" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource ContentBgBrush}"
        Icon="pack://application:,,,/Assets/Claudette.ico"
        AllowDrop="True"
        DragEnter="Window_DragEnter"
        Drop="Window_Drop">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- Theme is loaded dynamically from the Themes folder at startup -->
            </ResourceDictionary.MergedDictionaries>

            <!-- Base button -->
            <Style x:Key="ModernButton" TargetType="Button">
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="BorderBrush"     Value="{DynamicResource ControlBorderBrush}"/>
                <Setter Property="Cursor"          Value="Hand"/>
                <Setter Property="FontFamily"      Value="Segoe UI"/>
                <Setter Property="FontSize"        Value="13"/>
                <Setter Property="Padding"         Value="14,9"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="8"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Opacity" Value="0.82"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="Bd" Property="Opacity" Value="0.65"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="Bd" Property="Opacity" Value="0.38"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="SendButton" TargetType="Button" BasedOn="{StaticResource ModernButton}">
                <Setter Property="Background" Value="{DynamicResource PrimaryAccentBrush}"/>
                <Setter Property="Foreground" Value="{DynamicResource AccentTextBrush}"/>
                <Setter Property="FontWeight" Value="Bold"/>
            </Style>

            <Style x:Key="SidebarButton" TargetType="Button" BasedOn="{StaticResource ModernButton}">
                <Setter Property="Background" Value="{DynamicResource ControlBgBrush}"/>
                <Setter Property="Foreground" Value="{DynamicResource SidebarTextBrush}"/>
                <Setter Property="HorizontalAlignment" Value="Stretch"/>
                <Setter Property="Padding" Value="12,9"/>
            </Style>

            <!-- Tab button (Chat / Projects) -->
            <Style x:Key="TabButton" TargetType="Button">
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="FontFamily" Value="Segoe UI"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="Padding" Value="16,8,16,10"/>
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="8,8,0,0"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Opacity" Value="0.8"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Flat button — same as ModernButton but CornerRadius=0, for underline-tab style -->
            <Style x:Key="FlatButton" TargetType="Button">
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Cursor"          Value="Hand"/>
                <Setter Property="FontFamily"      Value="Segoe UI"/>
                <Setter Property="FontSize"        Value="12"/>
                <Setter Property="Padding"         Value="0,8"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Opacity" Value="0.82"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="Bd" Property="Opacity" Value="0.65"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- TextBox with fully custom template so WPF's Aero2 default
                 (white background, black text) never overrides our OXSUIT theme. -->
            <Style x:Key="ModernTextBox" TargetType="TextBox">
                <Setter Property="Background"        Value="{DynamicResource ControlBgBrush}"/>
                <Setter Property="Foreground"        Value="{DynamicResource InputTextBrush}"/>
                <Setter Property="BorderBrush"       Value="{DynamicResource ControlBorderBrush}"/>
                <Setter Property="CaretBrush"        Value="{DynamicResource InputTextBrush}"/>
                <Setter Property="SelectionBrush"    Value="{DynamicResource AccentHighlightBrush}"/>
                <Setter Property="SelectionOpacity"  Value="0.35"/>
                <Setter Property="BorderThickness"   Value="1"/>
                <Setter Property="Padding"           Value="8,6"/>
                <Setter Property="FontFamily"        Value="Segoe UI"/>
                <Setter Property="FontSize"          Value="13"/>
                <Setter Property="AllowDrop"         Value="True"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="TextBox">
                            <Border x:Name="Bd"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="6"
                                    SnapsToDevicePixels="True">
                                <!-- Background="Transparent" prevents the inner ScrollViewer
                                     from showing a system-white background in WPF Aero2. -->
                                <ScrollViewer x:Name="PART_ContentHost"
                                              Background="Transparent"
                                              Focusable="false"
                                              Padding="{TemplateBinding Padding}"
                                              HorizontalScrollBarVisibility="Hidden"
                                              VerticalScrollBarVisibility="Hidden"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="BorderBrush"
                                            Value="{DynamicResource AccentHighlightBrush}"/>
                                </Trigger>
                                <Trigger Property="IsFocused" Value="True">
                                    <Setter TargetName="Bd" Property="BorderBrush"
                                            Value="{DynamicResource AccentHighlightBrush}"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="Bd" Property="Opacity" Value="0.5"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- ComboBox — full custom template for theme-safe readability -->
            <!-- ModernComboBox is now defined in App.xaml (application scope)
                 so all windows can access it. Reference kept here for clarity. -->

            <!-- Popup model list: ListBoxItem style -->
            <Style x:Key="ModelListItem" TargetType="ListBoxItem">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Foreground" Value="{DynamicResource SidebarTextBrush}"/>
                <Setter Property="Padding" Value="8,6"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="FontFamily" Value="Segoe UI"/>
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ListBoxItem">
                            <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                    CornerRadius="6" Padding="{TemplateBinding Padding}">
                                <ContentPresenter/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background"
                                            Value="{DynamicResource ControlHoverBrush}"/>
                                </Trigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter TargetName="Bd" Property="Background"
                                            Value="{DynamicResource ControlBgBrush}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Toggle switch (CheckBox used as enable/disable toggle) -->
            <Style x:Key="ToggleSwitch" TargetType="CheckBox">
                <Setter Property="Foreground" Value="{DynamicResource ContentTextBrush}"/>
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="FontFamily" Value="Segoe UI"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="VerticalContentAlignment" Value="Center"/>
            </Style>

        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="264"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ══════════════════════════ SIDEBAR ══════════════════════════ -->
        <Border Grid.Column="0"
                Background="{DynamicResource SidebarBgBrush}"
                BorderBrush="{DynamicResource SidebarBorderBrush}"
                BorderThickness="0,0,1,0">
            <DockPanel>

                <!-- Footer -->
                <StackPanel DockPanel.Dock="Bottom" Margin="14,0,14,16">
                    <TextBlock x:Name="ThemeLabel"
                               Text="THEME" FontSize="10" FontWeight="Bold"
                               Foreground="{DynamicResource SidebarDimBrush}" Margin="2,0,0,6"/>
                    <ComboBox x:Name="ThemeComboBox"
                              Style="{StaticResource ModernComboBox}"
                              Margin="0,0,0,12"
                              SelectionChanged="ThemeComboBox_SelectionChanged"/>
                    <Rectangle Height="1" Fill="{DynamicResource ControlBgBrush}" Margin="0,0,0,12"/>
                    <Button x:Name="SettingsButton"
                            Content="👤  Config"
                            Style="{StaticResource SidebarButton}"
                            Margin="0,0,0,7"
                            ToolTip="Configure Chat Participants, Chat Settings and User Name"
                            Click="SettingsButton_Click"/>
                    <Button x:Name="ClearChatButton"
                            Content="🗑  Clear Chat"
                            Style="{StaticResource SidebarButton}"
                            Margin="0,0,0,6"
                            Click="ClearChat_Click"/>
                </StackPanel>

                <!-- Scrollable content -->
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Margin="14,20,14,8">

                        <!-- ── Logo ── -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,28">
                            <Button x:Name="ClaudetteButton"
                                    Click="Claudette_Click"
                                    Background="Transparent" BorderThickness="0"
                                    Padding="0" Cursor="Hand"
                                    ToolTip="Click me for help! 🐙"
                                    Margin="0,0,10,0">
                                <Image Source="pack://application:,,,/Assets/Claudette.png"
                                       Width="44" Height="44"
                                       RenderOptions.BitmapScalingMode="HighQuality"/>
                            </Button>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock FontSize="17" FontWeight="Bold" FontFamily="Segoe UI">
                                    <Run Text="Claudet" Foreground="{DynamicResource PrimaryAccentBrush}"/>
                                    <Run Text=" "/><Run Text="Relay" Foreground="{DynamicResource TertiaryAccentBrush}"/>
                                </TextBlock>
                                <TextBlock x:Name="MultiAiSubtitle"
                                           Text="Multi-AI Chat" FontSize="10"
                                           Foreground="{DynamicResource SidebarDimBrush}"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- ── Claudette speech bubble (shown while log summarisation runs) ── -->
                        <Border x:Name="ClaudetteSpeechBubble"
                                Visibility="Collapsed"
                                Background="{DynamicResource ControlHoverBrush}"
                                BorderBrush="{DynamicResource AccentHighlightBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="8,6"
                                Margin="0,-18,0,10">
                            <TextBlock x:Name="ClaudetteSpeechText"
                                       FontSize="11"
                                       FontFamily="Segoe UI"
                                       TextWrapping="Wrap"
                                       Foreground="{DynamicResource SidebarTextBrush}"/>
                        </Border>

                        <!-- ── Participants ── -->
                        <TextBlock x:Name="ParticipantsLabel"
                                   Text="PARTICIPANTS" FontSize="10" FontWeight="Bold"
                                   Foreground="{DynamicResource SidebarDimBrush}" Margin="2,0,0,10"/>

                        <!-- ── Welcome hint (visible when no participants are configured) ── -->
                        <Border x:Name="WelcomeHint"
                                Visibility="Collapsed"
                                Background="{DynamicResource ControlBgBrush}"
                                BorderBrush="{DynamicResource ControlBorderBrush}"
                                BorderThickness="1" CornerRadius="8"
                                Padding="13,12,13,13" Margin="0,0,0,10">
                            <StackPanel>
                                <TextBlock x:Name="WelcomeTitle"
                                           Text="No participants yet 🐙"
                                           FontSize="16" FontWeight="SemiBold"
                                           FontFamily="Segoe UI"
                                           Foreground="{DynamicResource ContentTextBrush}"
                                           TextWrapping="Wrap" Margin="0,0,0,12"/>
                                <TextBlock FontSize="13" FontFamily="Segoe UI"
                                           Foreground="{DynamicResource SidebarDimBrush}"
                                           TextWrapping="Wrap" LineHeight="21">
                                    <Run Text="1. "/>
                                    <Run Text="● ● ●" FontWeight="Bold" Foreground="{DynamicResource PrimaryAccentBrush}"/>
                                    <Run x:Name="WelcomeRun_TopRight" Text=" top-right menu"/>
                                    <Run Text="&#x0a;"/>
                                    <Run x:Name="WelcomeRun_ApiKeys" Text="     → Providers — enter API keys&#x0a;"/>
                                    <Run Text="2. "/>
                                    <Run Text="👤 Config" FontWeight="Bold" Foreground="{DynamicResource ContentTextBrush}"/>
                                    <Run x:Name="WelcomeRun_ConfigBtn" Text=" button below&#x0a;"/>
                                    <Run x:Name="WelcomeRun_ConfigModels" Text="     → configure models&#x0a;"/>
                                    <Run Text="3. Click "/>
                                    <Run Text="Claudette" FontWeight="Bold" Foreground="{DynamicResource PrimaryAccentBrush}"/>
                                    <Run x:Name="WelcomeRun_ForHelp" Text=" above for help 🐙"/>
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <!-- ── Participant cards (dynamic, ordered by slot 1–20) ── -->
                        <StackPanel x:Name="ParticipantsPanel"/>

                        <Button x:Name="AddParticipantButton"
                                Content="+ Add Participant"
                                Style="{StaticResource SidebarButton}"
                                Foreground="{DynamicResource SidebarTextBrush}"
                                Margin="0,0,0,7"
                                Click="AddParticipantButton_Click"/>



                    </StackPanel>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- ══════════════════════════ MAIN AREA ══════════════════════════ -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>  <!-- Row 0: Tab bar -->
                <RowDefinition Height="Auto"/>  <!-- Row 1: Chat header (hidden in Projects tab) -->
                <RowDefinition Height="*"/>     <!-- Row 2: Content (chat or projects) -->
                <RowDefinition Height="Auto"/>  <!-- Row 3: Input (hidden in Projects tab) -->
            </Grid.RowDefinitions>

            <!-- ── Tab bar (Row 0) — hidden when a project is open ── -->
            <Border x:Name="MainTabBar" Grid.Row="0" Background="{DynamicResource SidebarBgBrush}"
                    Padding="12,6,22,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <Button x:Name="ChatTabButton"
                                Content="💬  Chat"
                                Style="{StaticResource TabButton}"
                                FontWeight="SemiBold"
                                Click="ChatTabButton_Click">
                            <Button.Foreground>
                                <DynamicResource ResourceKey="SidebarTextBrush"/>
                            </Button.Foreground>
                            <Button.Background>
                                <DynamicResource ResourceKey="ControlBgBrush"/>
                            </Button.Background>
                        </Button>
                        <Button x:Name="ProjectsTabButton"
                                Content="📁  Projects"
                                Style="{StaticResource TabButton}"
                                Click="ProjectsTabButton_Click">
                            <Button.Foreground>
                                <DynamicResource ResourceKey="SidebarDimBrush"/>
                            </Button.Foreground>
                        </Button>
                        <Button x:Name="BridgeTabButton"
                                Content="🔌  Bridge"
                                Style="{StaticResource TabButton}"
                                Click="BridgeTabButton_Click">
                            <Button.Foreground>
                                <DynamicResource ResourceKey="SidebarDimBrush"/>
                            </Button.Foreground>
                        </Button>
                    </StackPanel>
                    <Button x:Name="OptionsMenuButton"
                            Grid.Column="1" VerticalAlignment="Bottom"
                            Margin="0,0,0,8" Padding="4,6"
                            Style="{StaticResource ModernButton}"
                            Background="Transparent"
                            ToolTip="Options"
                            Click="OptionsMenuButton_Click">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Ellipse Width="9" Height="9" Fill="{DynamicResource PrimaryAccentBrush}"   Margin="0,0,5,0"/>
                            <Ellipse Width="9" Height="9" Fill="{DynamicResource SecondaryAccentBrush}" Margin="0,0,5,0"/>
                            <Ellipse Width="9" Height="9" Fill="{DynamicResource TertiaryAccentBrush}"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </Border>

            <!-- ── Chat header (Row 1) ── -->
            <Border x:Name="ChatHeader" Grid.Row="1"
                    Background="{DynamicResource SidebarBgBrush}" Padding="22,10,16,10">
                <Grid>
                    <TextBlock x:Name="ChatHeaderTitle"
                               Text="Chat"
                               FontSize="15" FontWeight="SemiBold"
                               FontFamily="Segoe UI"
                               Foreground="{DynamicResource SidebarTextBrush}"
                               VerticalAlignment="Center"/>
                    <StackPanel HorizontalAlignment="Right" VerticalAlignment="Center"
                                Orientation="Horizontal">

                        <!-- Chat-only utility buttons — hidden when a project sub-panel is active -->
                        <StackPanel x:Name="ChatOnlyButtonsPanel" Orientation="Horizontal">
                            <Button x:Name="ExportChatButton"
                                    Content="📄"
                                    Style="{StaticResource ModernButton}"
                                    Background="{DynamicResource ControlBgBrush}"
                                    Foreground="{DynamicResource SidebarDimBrush}"
                                    FontSize="13" Padding="10,5"
                                    Margin="0,0,6,0"
                                    Click="ExportChatButton_Click"
                                    ToolTip="Export chat history as HTML or Markdown…"/>
                            <Button x:Name="ChatFontButton"
                                    Content="Aa"
                                    Style="{StaticResource ModernButton}"
                                    Background="{DynamicResource ControlBgBrush}"
                                    Foreground="{DynamicResource SidebarDimBrush}"
                                    FontSize="12" Padding="10,5"
                                    Margin="0,0,6,0"
                                    Click="ChatFontButton_Click"
                                    ToolTip="Chat font and size"/>
                            <Button x:Name="AiDialogueButton"
                                    Content="💬"
                                    Style="{StaticResource ModernButton}"
                                    Background="{DynamicResource ControlBgBrush}"
                                    Foreground="{DynamicResource SidebarDimBrush}"
                                    FontSize="13" Padding="10,5"
                                    Margin="0,0,18,0"
                                    Click="AiDialogueButton_Click"
                                    ToolTip="Multi-round AI dialogue — participants read and reply to each other (AllRespond mode)"/>
                        </StackPanel>

                        <!-- Project sub-view tab row — visible when a project is open -->
                        <Button x:Name="ChatViewButton"
                                Content="💬 Chat"
                                Visibility="Collapsed"
                                Style="{StaticResource ModernButton}"
                                Background="{DynamicResource ControlBgBrush}"
                                Foreground="{DynamicResource SidebarTextBrush}"
                                FontWeight="SemiBold"
                                FontSize="12" Padding="10,5"
                                Margin="0,0,6,0"
                                Click="ChatViewButton_Click"
                                ToolTip="Show project chat"/>
                        <Button x:Name="WorldButton"
                                Content="🌍 World"
                                Visibility="Collapsed"
                                Style="{StaticResource ModernButton}"
                                Background="{DynamicResource ControlBgBrush}"
                                Foreground="{DynamicResource SidebarTextBrush}"
                                FontSize="12" Padding="10,5"
                                Margin="0,0,6,0"
                                Click="WorldButton_Click"
                                ToolTip="Characters, Factions, Locations and World Lore"/>
                        <Button x:Name="RoadmapButton"
                                Content="📊 Roadmap"
                                Visibility="Collapsed"
                                Style="{StaticResource ModernButton}"
                                Background="{DynamicResource ControlBgBrush}"
                                Foreground="{DynamicResource SidebarTextBrush}"
                                FontSize="12" Padding="10,5"
                                Margin="0,0,6,0"
                                Click="RoadmapButton_Click"
                                ToolTip="Project roadmap"/>
                        <Button x:Name="FilesButton"
                                Content="📂 Files"
                                Visibility="Collapsed"
                                Style="{StaticResource ModernButton}"
                                Background="{DynamicResource ControlBgBrush}"
                                Foreground="{DynamicResource SidebarTextBrush}"
                                FontSize="12" Padding="10,5"
                                Margin="0,0,18,0"
                                Click="FilesButton_Click"
                                ToolTip="Browse and manage project files"/>

                        <!-- Project management buttons -->
                        <Button x:Name="BackupButton"
                                Content="💾"
                                Visibility="Collapsed"
                                Style="{StaticResource ModernButton}"
                                Background="{DynamicResource ControlBgBrush}"
                                Foreground="{DynamicResource SidebarTextBrush}"
                                FontSize="12" Padding="10,5"
                                Margin="0,0,6,0"
                                Click="BackupButton_Click"
                                ToolTip="Create a ZIP backup of this project now"/>
                        <Button x:Name="CloseProjectButton"
                                Content="✕ Close"
                                Visibility="Collapsed"
                                Style="{StaticResource ModernButton}"
                                Background="{DynamicResource ControlBgBrush}"
                                Foreground="{DynamicResource SidebarTextBrush}"
                                FontSize="12" Padding="10,5"
                                Margin="0,0,6,0"
                                Click="CloseProjectButton_Click"
                                ToolTip="Save and close the current project"/>
                        <Button x:Name="ProjectSettingsButton"
                                Content="⚙"
                                Visibility="Collapsed"
                                Style="{StaticResource ModernButton}"
                                Background="{DynamicResource ControlBgBrush}"
                                Foreground="{DynamicResource SidebarTextBrush}"
                                FontSize="12" Padding="10,5"
                                Click="ProjectSettingsButton_Click"
                                ToolTip="Open project settings (roles, orchestration mode)"/>
                    </StackPanel>
                </Grid>
            </Border>
            <Rectangle x:Name="ChatHeaderSep" Grid.Row="1" Height="1" VerticalAlignment="Bottom"
                       Fill="{DynamicResource ControlBgBrush}"/>

            <!-- ── Content area (Row 2) — Chat and Projects layered ── -->

            <!-- Chat scrollviewer -->
            <ScrollViewer x:Name="ChatScrollViewer" Grid.Row="2"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Padding="20,12,20,12">
                <StackPanel x:Name="ChatPanel"/>
            </ScrollViewer>

            <!-- Roadmap panel (shown when RoadmapButton is active) -->
            <Grid x:Name="RoadmapContent" Grid.Row="2" Visibility="Collapsed"/>

            <!-- Files panel (shown when FilesButton is active) -->
            <Grid x:Name="FilesContent" Grid.Row="2" Visibility="Collapsed"/>

            <!-- World editor panel (shown when WorldButton is active) -->
            <Grid x:Name="WorldContent" Grid.Row="2" Visibility="Collapsed"/>

            <!-- Bridge / MCP panel (shown when BridgeTabButton is active) -->
            <Grid x:Name="BridgeContent" Grid.Row="2" Visibility="Collapsed"/>

            <!-- Projects panel (hidden in Chat mode) -->
            <Grid x:Name="ProjectsContent" Grid.Row="2" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Projects subheader -->
                <Border Grid.Row="0" Background="{DynamicResource SidebarBgBrush}" Padding="22,13">
                    <TextBlock x:Name="ProjectsTitle"
                               Text="Projects" FontSize="15" FontWeight="SemiBold"
                               FontFamily="Segoe UI" Foreground="{DynamicResource SidebarTextBrush}"/>
                </Border>
                <Rectangle Grid.Row="0" Height="1" VerticalAlignment="Bottom"
                           Fill="{DynamicResource ControlBgBrush}"/>

                <!-- Sort toolbar -->
                <Border Grid.Row="1" Background="{DynamicResource SidebarBgBrush}" Padding="16,10,16,10">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock x:Name="SortLabel"
                                   Text="Sort:" FontSize="12" FontFamily="Segoe UI"
                                   VerticalAlignment="Center" Margin="0,0,8,0"
                                   Foreground="{DynamicResource SidebarDimBrush}"/>
                        <Button x:Name="SortAlphabetButton" Content="A–Z" FontSize="11"
                                Style="{StaticResource ModernButton}"
                                Background="{DynamicResource ControlBgBrush}"
                                Foreground="{DynamicResource SidebarTextBrush}"
                                Padding="10,6,10,6" Margin="0,0,6,0" Click="SortProjects_Click"
                                ToolTip="Sort alphabetically"/>
                        <Button x:Name="SortLastOpenedButton" Content="Last Opened" FontSize="11"
                                Style="{StaticResource ModernButton}"
                                Background="{DynamicResource ControlBgBrush}"
                                Foreground="{DynamicResource SidebarDimBrush}"
                                Padding="10,6,10,6" Click="SortProjects_Click"
                                ToolTip="Sort by last opened date"/>
                        <Button x:Name="RefreshProjectsButton" Content="🔄 Refresh" FontSize="11"
                                Style="{StaticResource ModernButton}"
                                Background="{DynamicResource ControlBgBrush}"
                                Foreground="{DynamicResource SidebarDimBrush}"
                                Padding="10,6,10,6" Margin="8,0,0,0" Click="RefreshProjectsButton_Click"
                                ToolTip="Refresh project list (reload from disk)"/>
                    </StackPanel>
                </Border>
                <Rectangle Grid.Row="1" Height="1" VerticalAlignment="Bottom"
                           Fill="{DynamicResource ControlBgBrush}"/>

                <!-- Project list (card grid) -->
                <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Padding="20,16,20,16">
                    <WrapPanel x:Name="ProjectListPanel" ItemWidth="232"/>
                </ScrollViewer>

                <!-- Project action bar -->
                <Border Grid.Row="3" Background="{DynamicResource SidebarBgBrush}" Padding="16,12,16,16">
                    <StackPanel>
                        <Rectangle Height="1" Fill="{DynamicResource ControlBgBrush}" Margin="0,0,0,12"/>
                        <StackPanel Orientation="Horizontal">
                            <Button Content="+ New Project"
                                    x:Name="NewProjectButton"
                                    Style="{StaticResource ModernButton}"
                                    Background="{DynamicResource ControlBgBrush}"
                                    Foreground="{DynamicResource PrimaryAccentBrush}"
                                    Margin="0,0,8,0"
                                    Click="NewProject_Click"/>
                            <Button Content="Open"
                                    x:Name="OpenProjectButton"
                                    Style="{StaticResource ModernButton}"
                                    Background="{DynamicResource ControlBgBrush}"
                                    Foreground="{DynamicResource SidebarTextBrush}"
                                    IsEnabled="False"
                                    Margin="0,0,8,0"
                                    Click="OpenProject_Click"/>
                            <Button Content="Delete"
                                    x:Name="DeleteProjectButton"
                                    Style="{StaticResource ModernButton}"
                                    Background="{DynamicResource ControlBgBrush}"
                                    Foreground="{DynamicResource AccentHighlightBrush}"
                                    IsEnabled="False"
                                    Click="DeleteProject_Click"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- ── Input (Row 3) ── -->
            <Border x:Name="InputArea" Grid.Row="3"
                    Background="{DynamicResource SidebarBgBrush}" Padding="16,12,16,16">
                <StackPanel x:Name="InputAreaStack">
                    <Rectangle Height="1" Fill="{DynamicResource ControlBgBrush}" Margin="0,0,0,12"/>

                    <!-- File read progress bar (hidden during normal operation) -->
                    <Border x:Name="FileReadProgressArea" Visibility="Collapsed" Margin="0,0,0,6">
                        <StackPanel>
                            <TextBlock x:Name="FileReadProgressLabel"
                                       Text=""
                                       Foreground="{DynamicResource SidebarDimBrush}"
                                       FontSize="12" FontFamily="Segoe UI"
                                       Margin="0,0,0,4"/>
                            <ProgressBar x:Name="FileReadProgressBar"
                                         Height="3"
                                         Minimum="0" Maximum="1" Value="0"
                                         Foreground="{DynamicResource SecondaryAccentBrush}"
                                         Background="{DynamicResource ControlBgBrush}"
                                         BorderThickness="0"/>
                        </StackPanel>
                    </Border>

                    <!-- Compression progress bar (hidden during normal operation) -->
                    <Border x:Name="CompressionProgressArea" Visibility="Collapsed" Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock x:Name="CompressionProgressLabel"
                                       Text="🗜  Compressing conversation history…"
                                       Foreground="{DynamicResource SidebarDimBrush}"
                                       FontSize="12" FontFamily="Segoe UI"
                                       Margin="0,0,0,5"/>
                            <ProgressBar x:Name="CompressionProgressBar"
                                         IsIndeterminate="True"
                                         Height="4"
                                         Foreground="{DynamicResource PrimaryAccentBrush}"
                                         Background="{DynamicResource ControlBgBrush}"
                                         BorderThickness="0"/>
                        </StackPanel>
                    </Border>

                    <!-- Private-message target chip (address line, shown above when recipient selected) -->
                    <Border x:Name="PrivateMsgChip" Visibility="Collapsed"
                            CornerRadius="8" Margin="0,0,0,8" Padding="10,5,6,5"
                            BorderThickness="1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="PrivateMsgChipText" Grid.Column="0"
                                       FontSize="12" FontFamily="Segoe UI"
                                       VerticalAlignment="Center"/>
                            <Button x:Name="PrivateMsgClearButton" Grid.Column="1"
                                    Content="×" FontSize="14" FontWeight="Bold"
                                    Width="24" Height="24" Padding="0"
                                    BorderThickness="0" Background="Transparent"
                                    Cursor="Hand" Margin="6,0,0,0"
                                    Click="PrivateMsgClear_Click"/>
                        </Grid>
                    </Border>

                    <!-- Input row: Recipient picker (left) → Message input → Buttons + Send (right) -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Column 0: Dictation power + mic buttons above whisper/recipient picker -->
                        <StackPanel Grid.Column="0" Orientation="Vertical" Margin="0,0,6,0">
                            <Button x:Name="DictationPowerButton"
                                    Content="⏻"
                                    Style="{StaticResource ModernButton}"
                                    Background="{DynamicResource ControlBgBrush}"
                                    Foreground="{DynamicResource SidebarDimBrush}"
                                    FontSize="13" Width="42" Padding="4,4" Margin="0,0,0,2"
                                    ToolTip="Load / unload dictation model"
                                    Click="DictationPowerButton_Click"/>
                            <Button x:Name="MicButton"
                                    Content="🎙"
                                    Style="{StaticResource ModernButton}"
                                    Background="{DynamicResource ControlBgBrush}"
                                    Foreground="{DynamicResource SidebarDimBrush}"
                                    IsEnabled="False"
                                    FontSize="13" Width="42" Padding="4,4" Margin="0,0,0,4"
                                    ToolTip="Dictation (Voice Recognition)"
                                    Click="MicButton_Click"/>
                            <Button x:Name="PrivateMsgButton"
                                    Content="🤫"
                                    Style="{StaticResource ModernButton}"
                                    Background="{DynamicResource ControlBgBrush}"
                                    Foreground="{DynamicResource SidebarDimBrush}"
                                    FontSize="13" Width="42" Padding="4,9"
                                    Click="PrivateMsgButton_Click"/>
                        </StackPanel>

                        <!-- Column 1: Message input box (center) -->
                        <Border Grid.Column="1" Background="{DynamicResource InputBgBrush}"
                                BorderBrush="{DynamicResource InputBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="12" Margin="0,0,10,0">
                            <Grid Margin="14,10,14,10">
                                <TextBox x:Name="InputTextBox"
                                         Background="Transparent"
                                         Foreground="{DynamicResource InputTextBrush}"
                                         BorderThickness="0" FontSize="13" FontFamily="Segoe UI"
                                         TextWrapping="Wrap" AcceptsReturn="True" MaxLines="8"
                                         VerticalContentAlignment="Top"
                                         VerticalScrollBarVisibility="Auto"
                                         Padding="0,2,0,2"
                                         CaretBrush="{DynamicResource InputTextBrush}"
                                         SelectionBrush="{DynamicResource PrimaryAccentBrush}"
                                         PreviewKeyDown="InputTextBox_KeyDown"
                                         TextChanged="InputTextBox_TextChanged"/>
                                <TextBlock x:Name="PlaceholderText"
                                           Text="Type a message...  (Enter ↵ send  •  Shift+Enter for new line)"
                                           Foreground="{DynamicResource SidebarDimBrush}"
                                           FontSize="13" FontFamily="Segoe UI"
                                           VerticalAlignment="Top" Margin="0,2,0,0"
                                           IsHitTestVisible="False"/>
                            </Grid>
                        </Border>
                        <!-- Column 2: small context buttons above a full-width Send button.
                             While audio is playing the two small buttons repurpose themselves
                             as ⏭ Skip and ⏹ Stop (UpdateVoiceButtons handles this). -->
                        <Grid Grid.Column="2" VerticalAlignment="Bottom">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,6">
                                <!-- ↺ AI Respond button -->
                                <Button x:Name="AIRespondButton"
                                        Content="↺"
                                        Style="{StaticResource ModernButton}"
                                        Background="{DynamicResource SecondaryAccentBrush}"
                                        Foreground="{DynamicResource AccentTextBrush}"
                                        FontWeight="Bold" Width="42" Padding="4,9"
                                        Click="AIRespondOrSkip_Click"/>
                                <Button x:Name="AudioControlButton"
                                        Content="🔊"
                                        Style="{StaticResource ModernButton}"
                                        Background="{DynamicResource ControlBgBrush}"
                                        Foreground="{DynamicResource SidebarDimBrush}"
                                        FontSize="13" Width="42" Padding="4,9"
                                        Margin="6,0,0,0"
                                        Click="AudioControlButton_Click"/>
                                <Button x:Name="WebBrowsingButton"
                                        Content="🌐"
                                        Style="{StaticResource ModernButton}"
                                        Background="{DynamicResource ControlBgBrush}"
                                        Foreground="{DynamicResource SidebarDimBrush}"
                                        FontSize="13" Width="42" Padding="4,9"
                                        Margin="6,0,0,0"
                                        ToolTip="Web browsing — OFF (click to enable)"
                                        Click="WebBrowsingButton_Click"/>
                            </StackPanel>
                            <Button x:Name="SendButton" Grid.Row="1"
                                    Content="Send"
                                    Style="{StaticResource SendButton}"
                                    HorizontalAlignment="Stretch"
                                    Click="SendButton_Click"/>
                        </Grid>
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
